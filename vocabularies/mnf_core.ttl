@prefix mnf:    <http://example.org/manifest#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

# =============================================================================
# Manifest — Core Vocabulary
# =============================================================================
#
# A vocabulary for expressing structural knowledge about data beyond what is
# captured by storage formats alone. Covers: schemas, semantic types,
# constraints, derivations, aggregation relationships, physical layout,
# provenance, and known deficiencies.
#
# Design principles:
#   1. Combinators over opaque leaves: the system reasons about structure;
#      domain-specific semantics live in extensible leaf terms.
#   2. Description and verification are decoupled: the graph records what is
#      asserted; verification is performed by external tools whose results
#      are themselves recorded in the graph.
#   3. Physical and logical are both first-class: storage layout (ordering,
#      partitioning, file format) carries semantic weight and is expressible.
#   4. Named individuals over string literals: structural enumerations use
#      URI-identified individuals for queryability and typo safety.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. Datasets, Files, and Schemas
# -----------------------------------------------------------------------------

mnf:Dataset a rdfs:Class ;
    rdfs:comment """A logical collection of data files sharing a common schema
        and structural invariants. A dataset may be partitioned across many
        physical files.""" .

mnf:DataFile a rdfs:Class ;
    rdfs:comment "A single physical data file within a dataset." .

mnf:Column a rdfs:Class ;
    rdfs:comment "A column within a dataset's schema." .

mnf:ColumnGroup a rdfs:Class ;
    rdfs:comment """A named group of columns that together carry a composite
        semantic meaning (e.g. a coordinate pair, an address).""" .

# --- Dataset properties ---

mnf:hasColumn a rdf:Property ;
    rdfs:domain mnf:Dataset ;
    rdfs:range mnf:Column ;
    rdfs:comment "Links a dataset to a column in its schema." .

mnf:hasColumnGroup a rdf:Property ;
    rdfs:domain mnf:Dataset ;
    rdfs:range mnf:ColumnGroup ;
    rdfs:comment "Links a dataset to a composite column group." .

mnf:partitionedBy a rdf:Property ;
    rdfs:domain mnf:Dataset ;
    rdfs:range mnf:PartitionScheme ;
    rdfs:comment "Declares how a dataset is split across physical files." .

# --- Column properties ---

mnf:columnName a rdf:Property ;
    rdfs:domain mnf:Column ;
    rdfs:range xsd:string ;
    rdfs:comment "The physical column name in the storage format." .

mnf:physicalType a rdf:Property ;
    rdfs:domain mnf:Column ;
    rdfs:range mnf:PhysicalType ;
    rdfs:comment """The expected storage-level type. Validators can check
        actual file metadata against this declaration.""" .

mnf:semanticType a rdf:Property ;
    rdfs:domain mnf:Column ;
    rdfs:range mnf:SemanticType ;
    rdfs:comment "The domain-meaningful type of values in this column." .

mnf:nullable a rdf:Property ;
    rdfs:domain mnf:Column ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Whether null values are expected/permitted." .

mnf:memberOf a rdf:Property ;
    rdfs:domain mnf:Column ;
    rdfs:range mnf:ColumnGroup ;
    rdfs:comment "Links a column to a column group it participates in." .

# --- ColumnGroup properties ---

mnf:groupSemanticType a rdf:Property ;
    rdfs:domain mnf:ColumnGroup ;
    rdfs:range mnf:SemanticType ;
    rdfs:comment "The composite semantic type of the column group." .

mnf:groupMember a rdf:Property ;
    rdfs:domain mnf:ColumnGroup ;
    rdfs:range mnf:Column ;
    rdfs:comment "A column that participates in this group." .

mnf:memberRole a rdf:Property ;
    rdfs:comment """The role a column plays within a group (e.g. 'latitude'
        within a coordinate pair). Domain is a blank node linking column
        to group.""" .


# -----------------------------------------------------------------------------
# 2. Physical Types
# -----------------------------------------------------------------------------
#
# Storage-level data types. Named using DuckDB conventions (which map
# directly to Parquet logical types). The point is to catch mismatches
# between declared and actual types — e.g. MMSI stored as VARCHAR when
# it should be INTEGER.
# -----------------------------------------------------------------------------

mnf:PhysicalType a rdfs:Class ;
    rdfs:comment "A storage-level data type." .

mnf:Boolean       a mnf:PhysicalType ; rdfs:label "BOOLEAN" .
mnf:Integer       a mnf:PhysicalType ; rdfs:label "INTEGER" .
mnf:BigInt        a mnf:PhysicalType ; rdfs:label "BIGINT" .
mnf:UBigInt       a mnf:PhysicalType ; rdfs:label "UBIGINT" .
mnf:Float         a mnf:PhysicalType ; rdfs:label "FLOAT" .
mnf:Double        a mnf:PhysicalType ; rdfs:label "DOUBLE" .
mnf:Varchar       a mnf:PhysicalType ; rdfs:label "VARCHAR" .
mnf:Date          a mnf:PhysicalType ; rdfs:label "DATE" .
mnf:TimestampTZ   a mnf:PhysicalType ; rdfs:label "TIMESTAMP WITH TIME ZONE" .
mnf:Blob          a mnf:PhysicalType ; rdfs:label "BLOB" .
mnf:IntegerList   a mnf:PhysicalType ; rdfs:label "INTEGER[]" .
mnf:DoubleList    a mnf:PhysicalType ; rdfs:label "DOUBLE[]" .
mnf:VarcharList   a mnf:PhysicalType ; rdfs:label "VARCHAR[]" .

# Type compatibility (e.g. Integer is narrower than BigInt)
mnf:narrowerThan a rdf:Property ;
    rdfs:domain mnf:PhysicalType ;
    rdfs:range mnf:PhysicalType ;
    rdfs:comment "This type can safely widen to the target type." .

mnf:Integer mnf:narrowerThan mnf:BigInt .
mnf:BigInt  mnf:narrowerThan mnf:Double .
mnf:Float   mnf:narrowerThan mnf:Double .


# -----------------------------------------------------------------------------
# 3. Semantic Types
# -----------------------------------------------------------------------------
#
# URI-identified types that carry domain meaning. Each semantic type may
# declare a required physical type, value constraints, and metadata.
# These are the "opaque leaves" in the combinator framework.
# -----------------------------------------------------------------------------

mnf:SemanticType a rdfs:Class ;
    rdfs:comment """A domain-meaningful type. Identified by URI, extensible
        without modifying the core vocabulary.""" .

mnf:requiredPhysicalType a rdf:Property ;
    rdfs:domain mnf:SemanticType ;
    rdfs:range mnf:PhysicalType ;
    rdfs:comment """The physical type that a column of this semantic type MUST
        have. A mismatch is a validation error. This is the property that
        would have caught the MMSI-as-string bug.""" .

mnf:acceptablePhysicalType a rdf:Property ;
    rdfs:domain mnf:SemanticType ;
    rdfs:range mnf:PhysicalType ;
    rdfs:comment "A physical type that is acceptable (when multiple are OK)." .

mnf:valueRange a rdf:Property ;
    rdfs:domain mnf:SemanticType ;
    rdfs:range mnf:ValueRange ;
    rdfs:comment "Declares the valid value range for this type." .

mnf:unit a rdf:Property ;
    rdfs:domain mnf:SemanticType ;
    rdfs:range xsd:string ;
    rdfs:comment "The unit of measurement (e.g. 'degrees', 'knots', 'metres')." .

mnf:ValueRange a rdfs:Class .
mnf:minInclusive a rdf:Property ; rdfs:domain mnf:ValueRange ; rdfs:range xsd:decimal .
mnf:maxInclusive a rdf:Property ; rdfs:domain mnf:ValueRange ; rdfs:range xsd:decimal .
mnf:minExclusive a rdf:Property ; rdfs:domain mnf:ValueRange ; rdfs:range xsd:decimal .
mnf:maxExclusive a rdf:Property ; rdfs:domain mnf:ValueRange ; rdfs:range xsd:decimal .


# -----------------------------------------------------------------------------
# 4. Constraints
# -----------------------------------------------------------------------------
#
# The combinator layer. Constraints compose structurally; the system
# can reason about them without understanding leaf predicates.
# -----------------------------------------------------------------------------

mnf:Constraint a rdfs:Class ;
    rdfs:comment "Base class for all constraints." .

# --- Constraint targets ---
# What does the constraint apply to?

mnf:appliesToDataset a rdf:Property ;
    rdfs:domain mnf:Constraint ;
    rdfs:range mnf:Dataset .

mnf:appliesToColumn a rdf:Property ;
    rdfs:domain mnf:Constraint ;
    rdfs:range mnf:Column .

mnf:appliesToColumnGroup a rdf:Property ;
    rdfs:domain mnf:Constraint ;
    rdfs:range mnf:ColumnGroup .

# --- Constraint signatures ---
# What kind of input does the constraint operate on?

mnf:ScalarConstraint a rdfs:Class ;
    rdfs:subClassOf mnf:Constraint ;
    rdfs:comment "Constraint on individual scalar values." .

mnf:PairConstraint a rdfs:Class ;
    rdfs:subClassOf mnf:Constraint ;
    rdfs:comment "Constraint on pairs/tuples of values from multiple columns." .

mnf:SequenceConstraint a rdfs:Class ;
    rdfs:subClassOf mnf:Constraint ;
    rdfs:comment "Constraint on an ordered sequence of values." .

mnf:WindowedSequenceConstraint a rdfs:Class ;
    rdfs:subClassOf mnf:Constraint ;
    rdfs:comment """Constraint on sliding windows over an ordered sequence
        (e.g. consecutive pairs).""" .

mnf:DatasetConstraint a rdfs:Class ;
    rdfs:subClassOf mnf:Constraint ;
    rdfs:comment "Constraint on a dataset as a whole." .

mnf:GroupedConstraint a rdfs:Class ;
    rdfs:subClassOf mnf:Constraint ;
    rdfs:comment "Constraint that applies within groups defined by a key." .

# --- Combinators ---

mnf:ForEach a rdfs:Class ;
    rdfs:subClassOf mnf:Constraint ;
    rdfs:comment "Apply a scalar constraint to every value in a column." .

mnf:Paired a rdfs:Class ;
    rdfs:subClassOf mnf:Constraint ;
    rdfs:comment "Apply a constraint to tuples drawn from a column group." .

mnf:Ordered a rdfs:Class ;
    rdfs:subClassOf mnf:Constraint ;
    rdfs:comment """Apply a sequence constraint to values ordered by a
        specified column.""" .

mnf:Grouped a rdfs:Class ;
    rdfs:subClassOf mnf:Constraint ;
    rdfs:comment """Apply a constraint within each group defined by a
        grouping column.""" .

mnf:Conditional a rdfs:Class ;
    rdfs:subClassOf mnf:Constraint ;
    rdfs:comment "Apply a constraint only when a predicate holds." .

mnf:And a rdfs:Class ;
    rdfs:subClassOf mnf:Constraint ;
    rdfs:comment "All component constraints must hold." .

mnf:Or a rdfs:Class ;
    rdfs:subClassOf mnf:Constraint ;
    rdfs:comment "At least one component constraint must hold." .

# Combinator properties
mnf:innerConstraint a rdf:Property ;
    rdfs:comment "The constraint being composed by a combinator." .

mnf:groupingColumn a rdf:Property ;
    rdfs:comment "The column defining groups for a Grouped combinator." .

mnf:orderingColumn a rdf:Property ;
    rdfs:comment "The column defining order for an Ordered combinator." .

mnf:predicate a rdf:Property ;
    rdfs:comment "The predicate for a Conditional combinator." .

mnf:components a rdf:Property ;
    rdfs:comment "The component constraints for And/Or combinators." .

# --- Computational profile ---
# How expensive is it to verify this constraint?

mnf:ComputationalProfile a rdfs:Class .
mnf:SchemaCheckOnly   a mnf:ComputationalProfile ;
    rdfs:comment "Checkable from file metadata alone (e.g. physical type)." .
mnf:PerValueCheck     a mnf:ComputationalProfile ;
    rdfs:comment "Requires scanning individual values." .
mnf:FullScanRequired  a mnf:ComputationalProfile ;
    rdfs:comment "Requires reading the entire column/dataset." .
mnf:SequentialScan    a mnf:ComputationalProfile ;
    rdfs:comment "Requires reading values in order (e.g. monotonicity)." .
mnf:ExternalService   a mnf:ComputationalProfile ;
    rdfs:comment "Requires calling an external service (e.g. address validation)." .

mnf:computationalProfile a rdf:Property ;
    rdfs:domain mnf:Constraint ;
    rdfs:range mnf:ComputationalProfile .

# --- Validators ---

mnf:Validator a rdfs:Class .

mnf:PythonValidator a rdfs:Class ;
    rdfs:subClassOf mnf:Validator .

mnf:SPARQLValidator a rdfs:Class ;
    rdfs:subClassOf mnf:Validator .

mnf:DuckDBValidator a rdfs:Class ;
    rdfs:subClassOf mnf:Validator .

mnf:validator a rdf:Property ;
    rdfs:domain mnf:Constraint ;
    rdfs:range mnf:Validator .

mnf:module a rdf:Property ;
    rdfs:domain mnf:PythonValidator ;
    rdfs:range xsd:string .

mnf:function a rdf:Property ;
    rdfs:domain mnf:PythonValidator ;
    rdfs:range xsd:string .

mnf:query a rdf:Property ;
    rdfs:domain mnf:DuckDBValidator ;
    rdfs:range xsd:string .


# -----------------------------------------------------------------------------
# 5. Derivations
# -----------------------------------------------------------------------------
#
# Functional dependencies between columns or between datasets.
# "Column X is computed from columns Y, Z via function F."
# -----------------------------------------------------------------------------

mnf:Derivation a rdfs:Class ;
    rdfs:comment """A declaration that one column or dataset is derived from
        others via a known function.""" .

mnf:derivedColumn a rdf:Property ;
    rdfs:domain mnf:Derivation ;
    rdfs:range mnf:Column .

mnf:sourceColumn a rdf:Property ;
    rdfs:domain mnf:Derivation ;
    rdfs:range mnf:Column .

mnf:derivationFunction a rdf:Property ;
    rdfs:domain mnf:Derivation ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "URI identifying the derivation function." .

mnf:DerivationProperty a rdfs:Class .
mnf:Deterministic a mnf:DerivationProperty ;
    rdfs:comment "Same inputs always produce same output." .
mnf:Invertible a mnf:DerivationProperty ;
    rdfs:comment "The derivation can be reversed." .
mnf:Lossy a mnf:DerivationProperty ;
    rdfs:comment "Information is lost in the derivation." .

mnf:hasDerivationProperty a rdf:Property ;
    rdfs:domain mnf:Derivation ;
    rdfs:range mnf:DerivationProperty .


# -----------------------------------------------------------------------------
# 6. Aggregation Relationships
# -----------------------------------------------------------------------------
#
# "Dataset B is an aggregation of Dataset A, grouped by column K,
#  with column B.x = AGG(A.y) within each group."
# -----------------------------------------------------------------------------

mnf:AggregationRelationship a rdfs:Class ;
    rdfs:comment """Declares that a target dataset is derived from a source
        dataset by grouping and aggregating.""" .

mnf:sourceDataset a rdf:Property ;
    rdfs:domain mnf:AggregationRelationship ;
    rdfs:range mnf:Dataset .

mnf:targetDataset a rdf:Property ;
    rdfs:domain mnf:AggregationRelationship ;
    rdfs:range mnf:Dataset .

mnf:groupByColumn a rdf:Property ;
    rdfs:domain mnf:AggregationRelationship ;
    rdfs:range mnf:Column ;
    rdfs:comment "The column(s) defining groups in the source dataset." .

mnf:hasAggregatedColumn a rdf:Property ;
    rdfs:domain mnf:AggregationRelationship ;
    rdfs:range mnf:AggregatedColumn .

mnf:AggregatedColumn a rdfs:Class ;
    rdfs:comment "Defines how one target column is derived from source columns." .

mnf:targetColumn a rdf:Property ;
    rdfs:domain mnf:AggregatedColumn ;
    rdfs:range mnf:Column .

mnf:aggregationSourceColumn a rdf:Property ;
    rdfs:domain mnf:AggregatedColumn ;
    rdfs:range mnf:Column .

mnf:aggregationFunction a rdf:Property ;
    rdfs:domain mnf:AggregatedColumn ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "URI of the aggregation function." .

mnf:withinGroupOrdering a rdf:Property ;
    rdfs:domain mnf:AggregatedColumn ;
    rdfs:range mnf:Column ;
    rdfs:comment """The column that defines ordering within groups, required
        for order-dependent aggregations.""" .

# --- Standard aggregation functions ---

mnf:Min a rdfs:Resource ; rdfs:label "MIN" .
mnf:Max a rdfs:Resource ; rdfs:label "MAX" .
mnf:Mean a rdfs:Resource ; rdfs:label "MEAN / AVG" .
mnf:Sum a rdfs:Resource ; rdfs:label "SUM" .
mnf:Count a rdfs:Resource ; rdfs:label "COUNT" .
mnf:CountDistinct a rdfs:Resource ; rdfs:label "COUNT DISTINCT" .
mnf:DistinctList a rdfs:Resource ; rdfs:label "LIST of DISTINCT values" .
mnf:First a rdfs:Resource ; rdfs:label "First value in ordered sequence" .
mnf:Last a rdfs:Resource ; rdfs:label "Last value in ordered sequence" .


# -----------------------------------------------------------------------------
# 7. Physical Layout
# -----------------------------------------------------------------------------
#
# How the data is physically arranged: ordering within files,
# partitioning across files, file format.
# -----------------------------------------------------------------------------

mnf:PhysicalLayout a rdfs:Class .

mnf:hasPhysicalLayout a rdf:Property ;
    rdfs:domain mnf:Dataset ;
    rdfs:range mnf:PhysicalLayout .

mnf:fileFormat a rdf:Property ;
    rdfs:domain mnf:PhysicalLayout ;
    rdfs:range mnf:FileFormat ;
    rdfs:comment "The storage file format." .

# --- File format individuals ---

mnf:FileFormat a rdfs:Class ;
    rdfs:comment "A storage file format." .

mnf:Parquet a mnf:FileFormat ; rdfs:label "Parquet" .
mnf:CSV     a mnf:FileFormat ; rdfs:label "CSV" .
mnf:ORC     a mnf:FileFormat ; rdfs:label "ORC" .

# --- Row ordering ---

mnf:RowOrdering a rdfs:Class .
mnf:hasRowOrdering a rdf:Property ;
    rdfs:domain mnf:PhysicalLayout ;
    rdfs:range mnf:RowOrdering .

mnf:OrderingKey a rdfs:Class .
mnf:hasOrderingKey a rdf:Property ;
    rdfs:domain mnf:RowOrdering ;
    rdfs:range mnf:OrderingKey .

mnf:keyColumn a rdf:Property ;
    rdfs:domain mnf:OrderingKey ;
    rdfs:range mnf:Column .

mnf:keyDirection a rdf:Property ;
    rdfs:domain mnf:OrderingKey ;
    rdfs:range mnf:SortDirection ;
    rdfs:comment "The sort direction of this ordering key." .

mnf:keyPrecedence a rdf:Property ;
    rdfs:domain mnf:OrderingKey ;
    rdfs:range xsd:integer ;
    rdfs:comment "1 = primary, 2 = secondary, etc." .

mnf:orderingSemantic a rdf:Property ;
    rdfs:domain mnf:OrderingKey ;
    rdfs:range mnf:OrderingSemanticType ;
    rdfs:comment """Why this ordering exists. Distinguishes 'clustering for
        index efficiency' from 'meaningful temporal sequence'.""" .

# --- Sort direction individuals ---

mnf:SortDirection a rdfs:Class ;
    rdfs:comment "Direction of a sort key." .

mnf:Ascending  a mnf:SortDirection ; rdfs:label "ascending" .
mnf:Descending a mnf:SortDirection ; rdfs:label "descending" .

# --- Ordering semantic individuals ---

mnf:OrderingSemanticType a rdfs:Class .
mnf:ClusteringForIndex a mnf:OrderingSemanticType ;
    rdfs:comment "Equal values are grouped for min/max index efficiency." .
mnf:MeaningfulSequence a mnf:OrderingSemanticType ;
    rdfs:comment "The order carries domain meaning (e.g. temporal trajectory)." .
mnf:PerformanceOnly a mnf:OrderingSemanticType ;
    rdfs:comment "Ordering exists solely for query performance." .

# --- Partition scheme ---

mnf:PartitionScheme a rdfs:Class .

mnf:partitionColumn a rdf:Property ;
    rdfs:domain mnf:PartitionScheme ;
    rdfs:range mnf:Column ;
    rdfs:comment "Column whose values determine which file a row lives in." .

mnf:partitionGranularity a rdf:Property ;
    rdfs:domain mnf:PartitionScheme ;
    rdfs:range mnf:TemporalGranularity ;
    rdfs:comment "The temporal granularity of the partition." .

mnf:pathTemplate a rdf:Property ;
    rdfs:domain mnf:PartitionScheme ;
    rdfs:range xsd:string ;
    rdfs:comment """Path template with placeholders, e.g.
        'broadcasts/{year}/ais-{date}.parquet'""" .

mnf:redundantPartitionKey a rdf:Property ;
    rdfs:domain mnf:PartitionScheme ;
    rdfs:range mnf:Column ;
    rdfs:comment """A column embedded in the data whose value is constant
        within each partition and matches the partition value.
        Exists for query convenience.""" .

# --- Temporal granularity individuals ---

mnf:TemporalGranularity a rdfs:Class ;
    rdfs:comment "Granularity of a temporal partition or level." .

mnf:Daily   a mnf:TemporalGranularity ; rdfs:label "daily" .
mnf:Hourly  a mnf:TemporalGranularity ; rdfs:label "hourly" .
mnf:Monthly a mnf:TemporalGranularity ; rdfs:label "monthly" .
mnf:ByValue a mnf:TemporalGranularity ; rdfs:label "by_value" ;
    rdfs:comment "Partitioned by distinct values, not by time period." .


# -----------------------------------------------------------------------------
# 8. Provenance and Known Deficiencies
# -----------------------------------------------------------------------------

mnf:Provenance a rdfs:Class .

mnf:hasProvenance a rdf:Property ;
    rdfs:domain mnf:Dataset ;
    rdfs:range mnf:Provenance .

mnf:source a rdf:Property ;
    rdfs:domain mnf:Provenance ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "URI of the upstream data source." .

mnf:sourceDescription a rdf:Property ;
    rdfs:domain mnf:Provenance ;
    rdfs:range xsd:string .

mnf:Transformation a rdfs:Class .
mnf:hasTransformation a rdf:Property ;
    rdfs:domain mnf:Provenance ;
    rdfs:range mnf:Transformation .

mnf:transformationType a rdf:Property ;
    rdfs:domain mnf:Transformation ;
    rdfs:range xsd:string .

mnf:transformationDescription a rdf:Property ;
    rdfs:domain mnf:Transformation ;
    rdfs:range xsd:string .

# --- Known deficiencies ---
# Things the data SHOULD satisfy but DOESN'T, and we know it.

mnf:KnownDeficiency a rdfs:Class ;
    rdfs:comment """A known way in which the data fails to satisfy an ideal
        invariant. Crucial for integration: tells a consumer what NOT
        to assume.""" .

mnf:hasKnownDeficiency a rdf:Property ;
    rdfs:domain mnf:Dataset ;
    rdfs:range mnf:KnownDeficiency .

mnf:deficiencyDescription a rdf:Property ;
    rdfs:domain mnf:KnownDeficiency ;
    rdfs:range xsd:string .

mnf:violatedInvariant a rdf:Property ;
    rdfs:domain mnf:KnownDeficiency ;
    rdfs:range mnf:Constraint ;
    rdfs:comment """The constraint that WOULD hold on ideal data but does not
        hold here.""" .

mnf:impact a rdf:Property ;
    rdfs:domain mnf:KnownDeficiency ;
    rdfs:range xsd:string ;
    rdfs:comment "Description of downstream effects." .

mnf:severity a rdf:Property ;
    rdfs:domain mnf:KnownDeficiency ;
    rdfs:range mnf:SeverityLevel ;
    rdfs:comment "How severe the deficiency is." .

# --- Severity level individuals ---

mnf:SeverityLevel a rdfs:Class ;
    rdfs:comment "Severity of a known deficiency." .

mnf:Minor    a mnf:SeverityLevel ; rdfs:label "minor" .
mnf:Moderate a mnf:SeverityLevel ; rdfs:label "moderate" .
mnf:Severe   a mnf:SeverityLevel ; rdfs:label "severe" .


# -----------------------------------------------------------------------------
# 9. Verification Attestations
# -----------------------------------------------------------------------------
#
# Records of validation runs: who checked what, when, with what result.
# These are themselves part of the graph.
# -----------------------------------------------------------------------------

mnf:VerificationAttestation a rdfs:Class .

mnf:verifiedConstraint a rdf:Property ;
    rdfs:domain mnf:VerificationAttestation ;
    rdfs:range mnf:Constraint .

mnf:verifiedDataset a rdf:Property ;
    rdfs:domain mnf:VerificationAttestation ;
    rdfs:range mnf:Dataset .

mnf:verifiedFile a rdf:Property ;
    rdfs:domain mnf:VerificationAttestation ;
    rdfs:range mnf:DataFile .

mnf:verificationTime a rdf:Property ;
    rdfs:domain mnf:VerificationAttestation ;
    rdfs:range xsd:dateTime .

mnf:verificationResult a rdf:Property ;
    rdfs:domain mnf:VerificationAttestation ;
    rdfs:range mnf:VerificationResultValue ;
    rdfs:comment "The outcome of the verification run." .

mnf:verificationTool a rdf:Property ;
    rdfs:domain mnf:VerificationAttestation ;
    rdfs:range rdfs:Resource .

mnf:verificationDetails a rdf:Property ;
    rdfs:domain mnf:VerificationAttestation ;
    rdfs:range xsd:string ;
    rdfs:comment "Detailed output, error messages, statistics." .

# --- Verification result individuals ---

mnf:VerificationResultValue a rdfs:Class ;
    rdfs:comment "Outcome of a verification run." .

mnf:Pass    a mnf:VerificationResultValue ; rdfs:label "pass" .
mnf:Fail    a mnf:VerificationResultValue ; rdfs:label "fail" .
mnf:Partial a mnf:VerificationResultValue ; rdfs:label "partial" .
mnf:Error   a mnf:VerificationResultValue ; rdfs:label "error" .


# -----------------------------------------------------------------------------
# 10. Dataset Relationships
# -----------------------------------------------------------------------------
#
# Beyond aggregation: general relationships between datasets.
# -----------------------------------------------------------------------------

mnf:DatasetRelationship a rdfs:Class .

mnf:Companion a rdfs:Class ;
    rdfs:subClassOf mnf:DatasetRelationship ;
    rdfs:comment """Datasets that are co-partitioned and jointly maintained.
        E.g. daily broadcasts and their corresponding daily index.""" .

mnf:companionOf a rdf:Property ;
    rdfs:domain mnf:Dataset ;
    rdfs:range mnf:Dataset .

mnf:sharedPartitionScheme a rdf:Property ;
    rdfs:domain mnf:DatasetRelationship ;
    rdfs:range mnf:PartitionScheme ;
    rdfs:comment """The partition scheme shared between companion datasets,
        ensuring 1:1 alignment of files.""" .


# -----------------------------------------------------------------------------
# 11. Allowed Values (Categorical / Enum Constraints)
# -----------------------------------------------------------------------------
#
# Extends value constraints beyond numeric ranges to support enumerated
# string values. Motivated by prediction-market data where columns like
# trade side are constrained to {"BUY", "SELL"}.
# -----------------------------------------------------------------------------

mnf:AllowedValues a rdfs:Class ;
    rdfs:comment """A set of permitted values for a semantic type or column.
        Analogous to an enum constraint. Each allowed value is declared
        via mnf:allowedValue.""" .

mnf:hasAllowedValues a rdf:Property ;
    rdfs:domain mnf:SemanticType ;
    rdfs:range mnf:AllowedValues ;
    rdfs:comment "Links a semantic type to its set of allowed values." .

mnf:allowedValue a rdf:Property ;
    rdfs:domain mnf:AllowedValues ;
    rdfs:range xsd:string ;
    rdfs:comment "One permitted value in an AllowedValues set." .


# -----------------------------------------------------------------------------
# 12. Row Semantics and Snapshot / Entity Key
# -----------------------------------------------------------------------------
#
# Declares what each row represents (event, snapshot, aggregate) and,
# for snapshot datasets, which columns identify the entity and the
# point in time.
# -----------------------------------------------------------------------------

mnf:rowSemantics a rdf:Property ;
    rdfs:domain mnf:Dataset ;
    rdfs:range mnf:RowSemanticsType ;
    rdfs:comment """What each row in this dataset represents. Affects how
        consumers should interpret duplicates, ordering, and grouping.""" .

mnf:RowSemanticsType a rdfs:Class ;
    rdfs:comment "The semantic meaning of a single row." .

mnf:EventRow a mnf:RowSemanticsType ;
    rdfs:comment """Each row is an independent event or observation. Rows are
        not expected to share identity keys.""" .

mnf:SnapshotRow a mnf:RowSemanticsType ;
    rdfs:comment """Each row is a point-in-time observation of a recurring
        entity. The same entity appears in multiple rows across time.
        Datasets with snapshot rows should declare mnf:entityKey and
        mnf:snapshotTimestamp.""" .

mnf:AggregateRow a mnf:RowSemanticsType ;
    rdfs:comment """Each row summarises a group of source rows. Typically
        produced by grouping and aggregation from a source dataset.""" .

mnf:entityKey a rdf:Property ;
    rdfs:domain mnf:Dataset ;
    rdfs:range mnf:Column ;
    rdfs:comment """Declares that this dataset contains temporal snapshots of
        entities identified by this column. The same entity key value
        appears in multiple rows across time. Consumers should expect
        duplicates on this column and use the snapshot timestamp to
        select the desired point-in-time state.""" .

mnf:snapshotTimestamp a rdf:Property ;
    rdfs:domain mnf:Dataset ;
    rdfs:range mnf:Column ;
    rdfs:comment """The column that identifies the point in time for each
        snapshot. Used with mnf:entityKey to select a specific state
        of an entity. For Hive-partitioned snapshot stores, this may
        be a partition-derived column rather than a data column.""" .


# -----------------------------------------------------------------------------
# 13. Embedded Structure (Structured Data in String Columns)
# -----------------------------------------------------------------------------
#
# Describes the internal structure of columns whose physical type is
# Varchar but whose content is structured (e.g. JSON arrays, nested
# objects encoded as strings).
# -----------------------------------------------------------------------------

mnf:embeddedStructure a rdf:Property ;
    rdfs:domain mnf:Column ;
    rdfs:range mnf:EmbeddedStructure ;
    rdfs:comment """Declares that this column contains structured data encoded
        as a string. The EmbeddedStructure describes the internal format
        and schema.""" .

mnf:EmbeddedStructure a rdfs:Class ;
    rdfs:comment """Description of structured data embedded within a string
        column. Captures the encoding format and inner type.""" .

mnf:embeddedFormat a rdf:Property ;
    rdfs:domain mnf:EmbeddedStructure ;
    rdfs:range mnf:DataEncodingFormat ;
    rdfs:comment "Encoding format of the embedded data." .

mnf:embeddedElementType a rdf:Property ;
    rdfs:domain mnf:EmbeddedStructure ;
    rdfs:range xsd:string ;
    rdfs:comment """Description of the inner element type, e.g.
        'array<string>', 'array<{price: float, size: float}>'.""" .

# --- Data encoding format individuals ---

mnf:DataEncodingFormat a rdfs:Class ;
    rdfs:comment "Encoding format for embedded structured data." .

mnf:JSONEncoding a mnf:DataEncodingFormat ; rdfs:label "json" .
mnf:CSVEncoding  a mnf:DataEncodingFormat ; rdfs:label "csv" .


# -----------------------------------------------------------------------------
# 14. Composite Partition Scheme
# -----------------------------------------------------------------------------
#
# Extends partitioning to support multiple partition dimensions
# (e.g. dt=YYYY-MM-DD/hour=HH).
# -----------------------------------------------------------------------------

mnf:CompositePartitionScheme a rdfs:Class ;
    rdfs:subClassOf mnf:PartitionScheme ;
    rdfs:comment """A partition scheme with multiple partition dimensions.
        Each level is declared as a PartitionLevel with its own column
        and granularity.""" .

mnf:hasPartitionLevel a rdf:Property ;
    rdfs:domain mnf:CompositePartitionScheme ;
    rdfs:range mnf:PartitionLevel ;
    rdfs:comment "Links a composite scheme to one of its partition levels." .

mnf:PartitionLevel a rdfs:Class ;
    rdfs:comment "A single dimension in a composite partition scheme." .

mnf:levelPrecedence a rdf:Property ;
    rdfs:domain mnf:PartitionLevel ;
    rdfs:range xsd:integer ;
    rdfs:comment "Ordering of partition levels: 1 = outermost, 2 = next, etc." .

mnf:levelColumn a rdf:Property ;
    rdfs:domain mnf:PartitionLevel ;
    rdfs:range xsd:string ;
    rdfs:comment """Name of the partition key in the directory path. May not
        correspond to a data column (e.g. Hive partitions extracted from
        filenames, not embedded in data).""" .

mnf:levelGranularity a rdf:Property ;
    rdfs:domain mnf:PartitionLevel ;
    rdfs:range mnf:TemporalGranularity ;
    rdfs:comment "Granularity of this partition level." .


# -----------------------------------------------------------------------------
# 15. Foreign Key / Referential Relationships
# -----------------------------------------------------------------------------
#
# Declares that a column in one dataset references an entity identified
# by a column in another dataset. Unlike companionOf, this does not
# imply co-partitioning.
# -----------------------------------------------------------------------------

mnf:ForeignKey a rdfs:Class ;
    rdfs:comment """A referential relationship between a column in one dataset
        and a column in another dataset, declaring that values in the
        source column reference entities identified by the target column.
        Does not imply co-partitioning or structural alignment.""" .

mnf:foreignKeyFrom a rdf:Property ;
    rdfs:domain mnf:ForeignKey ;
    rdfs:range mnf:Column ;
    rdfs:comment "The referencing column (source side of the FK)." .

mnf:foreignKeyTo a rdf:Property ;
    rdfs:domain mnf:ForeignKey ;
    rdfs:range mnf:Column ;
    rdfs:comment "The referenced column (target side of the FK)." .

mnf:referentialIntegrity a rdf:Property ;
    rdfs:domain mnf:ForeignKey ;
    rdfs:range mnf:ReferentialIntegrityLevel ;
    rdfs:comment "Expected referential integrity level." .

# --- Referential integrity level individuals ---

mnf:ReferentialIntegrityLevel a rdfs:Class ;
    rdfs:comment "Expected referential integrity of a foreign key." .

mnf:StrictIntegrity a mnf:ReferentialIntegrityLevel ;
    rdfs:comment "Every FK value must exist in the target." .

mnf:EventualIntegrity a mnf:ReferentialIntegrityLevel ;
    rdfs:comment "FK values may temporarily be missing but will resolve." .

mnf:PartialIntegrity a mnf:ReferentialIntegrityLevel ;
    rdfs:comment "Some FK values may never resolve in the target." .


# -----------------------------------------------------------------------------
# 16. Schema Stability
# -----------------------------------------------------------------------------
#
# Declares how stable a dataset's schema is expected to be.
# Motivated by data stores where schemas are inferred from dynamic
# API responses rather than declared upfront.
# -----------------------------------------------------------------------------

mnf:schemaStability a rdf:Property ;
    rdfs:domain mnf:Dataset ;
    rdfs:range mnf:SchemaStabilityLevel ;
    rdfs:comment """How stable the dataset's column schema is. Affects whether
        consumers can rely on declared columns being present and having
        the declared types across all files.""" .

mnf:SchemaStabilityLevel a rdfs:Class .

mnf:FixedSchema a mnf:SchemaStabilityLevel ;
    rdfs:comment """Schema is declared and enforced. All files have the same
        columns with the same types. Missing columns are an error.""" .

mnf:InferredSchema a mnf:SchemaStabilityLevel ;
    rdfs:comment """Schema is inferred from data (e.g. by a data processing
        framework like Polars or Spark). Columns and types may vary
        between files depending on the data content.""" .

mnf:VariableSchema a mnf:SchemaStabilityLevel ;
    rdfs:comment """Schema is expected to change over time as the upstream
        source evolves. Columns may appear, disappear, or change type.""" .


# -----------------------------------------------------------------------------
# 17. Cross-Dataset Entity Identity
# -----------------------------------------------------------------------------
#
# Declares that columns across different datasets refer to the same
# logical entity. Different from companionOf (which implies co-partitioning)
# and ForeignKey (which implies a directional reference).
# -----------------------------------------------------------------------------

mnf:SameEntity a rdfs:Class ;
    rdfs:comment """A declaration that multiple columns across different
        datasets identify the same logical entity. Values in these columns
        can be joined to link records across datasets.""" .

mnf:identifyingColumn a rdf:Property ;
    rdfs:domain mnf:SameEntity ;
    rdfs:range mnf:Column ;
    rdfs:comment """A column that participates in this entity identity
        relationship. Multiple columns from different datasets can be
        linked via a single SameEntity declaration.""" .
