@prefix mnf:    <http://example.org/manifest#> .
@prefix pm:     <http://example.org/polymarket#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# Polymarket Data Store Description
# =============================================================================
#
# Describes the compacted Parquet data store produced by polymarket-fetcher:
# hourly Hive-partitioned snapshots of prediction-market data from Polymarket's
# Gamma API, CLOB API, and Data API.
#
# This description exercises Manifest against a fundamentally different domain than
# AIS maritime data, surfacing vocabulary gaps documented inline.
# =============================================================================


# =============================================================================
# PART 0: Manifest Vocabulary Gaps — Identified and Resolved
# =============================================================================
#
# Modelling this dataset surfaced 10 vocabulary gaps in the original Manifest core.
# Each has been addressed by extensions to mnf_core.ttl (sections 11–17).
# The descriptions below use the new vocabulary terms.
#
# Gap 1 — Snapshot semantics → mnf:entityKey
# Gap 2 — Enum/categorical constraints → mnf:AllowedValues, mnf:allowedValue
# Gap 3 — Structured-data-in-string → mnf:embeddedStructure, mnf:EmbeddedStructure
# Gap 4 — Multi-level partitioning → mnf:CompositePartitionScheme, mnf:PartitionLevel
# Gap 5 — Foreign key / referential → mnf:ForeignKey, mnf:foreignKeyFrom/To
# Gap 6 — Variable-type columns → documented via mnf:KnownDeficiency (no new
#          vocabulary needed; mnf:acceptablePhysicalType partially covers this)
# Gap 7 — Non-semantic ordering → omit mnf:hasRowOrdering (already supported)
# Gap 8 — Nested/repeated fields → mnf:embeddedStructure with embeddedElementType
# Gap 9 — Schema stability → mnf:schemaStability, mnf:InferredSchema
# Gap 10 — Cross-dataset entity identity → mnf:SameEntity, mnf:identifyingColumn
# =============================================================================


# =============================================================================
# PART 1: Polymarket Domain Semantic Types
# =============================================================================

# --- Identifiers ---

pm:MarketId a mnf:SemanticType ;
    rdfs:label "Polymarket Market ID" ;
    rdfs:comment """Unique identifier for a prediction market on Polymarket's
        Gamma API. Varchar string, typically a short alphanumeric slug.""" ;
    mnf:requiredPhysicalType mnf:Varchar .

pm:EventId a mnf:SemanticType ;
    rdfs:label "Polymarket Event ID" ;
    rdfs:comment """Unique identifier for an event (a grouping of related
        markets) on Polymarket's Gamma API.""" ;
    mnf:requiredPhysicalType mnf:Varchar .

pm:CLOBTokenId a mnf:SemanticType ;
    rdfs:label "CLOB Token ID" ;
    rdfs:comment """Identifier for a tradable token on Polymarket's CLOB
        (Central Limit Order Book). Each market outcome has a distinct
        token ID. Long numeric string.""" ;
    mnf:requiredPhysicalType mnf:Varchar .

pm:ConditionId a mnf:SemanticType ;
    rdfs:label "On-Chain Condition ID" ;
    rdfs:comment """Hex-encoded blockchain condition identifier linking a
        Polymarket market to its on-chain resolution contract. Serves as
        the primary cross-system join key between gamma/markets, trades,
        and holders.""" ;
    mnf:requiredPhysicalType mnf:Varchar .

pm:ProxyWallet a mnf:SemanticType ;
    rdfs:label "Proxy Wallet Address" ;
    rdfs:comment "Ethereum proxy wallet address for a Polymarket trader." ;
    mnf:requiredPhysicalType mnf:Varchar .

pm:TransactionHash a mnf:SemanticType ;
    rdfs:label "Transaction Hash" ;
    rdfs:comment "On-chain transaction hash for a trade settlement." ;
    mnf:requiredPhysicalType mnf:Varchar .

pm:Slug a mnf:SemanticType ;
    rdfs:label "URL Slug" ;
    rdfs:comment "URL-safe slug used in Polymarket URLs." ;
    mnf:requiredPhysicalType mnf:Varchar .

# --- Prices and probabilities ---

pm:Probability a mnf:SemanticType ;
    rdfs:label "Probability" ;
    rdfs:comment """Price interpreted as a probability. On Polymarket,
        prices of outcome tokens range from 0.0 to 1.0, representing the
        market-implied probability of that outcome.""" ;
    mnf:requiredPhysicalType mnf:Double ;
    mnf:valueRange [
        mnf:minInclusive 0.0 ;
        mnf:maxInclusive 1.0
    ] .

pm:USDAmount a mnf:SemanticType ;
    rdfs:label "USD Amount" ;
    rdfs:comment "Dollar amount. Volume, liquidity, etc." ;
    mnf:requiredPhysicalType mnf:Double ;
    mnf:unit "USD" ;
    mnf:valueRange [ mnf:minInclusive 0.0 ] .

pm:PriceSpread a mnf:SemanticType ;
    rdfs:label "Bid-Ask Spread" ;
    rdfs:comment "Difference between best ask and best bid prices." ;
    mnf:requiredPhysicalType mnf:Double ;
    mnf:valueRange [ mnf:minInclusive 0.0 ] .

pm:PriceChange a mnf:SemanticType ;
    rdfs:label "Price Change" ;
    rdfs:comment "Absolute change in price over a time window. Can be negative." ;
    mnf:requiredPhysicalType mnf:Double .

# --- Quantities ---

pm:TradeSize a mnf:SemanticType ;
    rdfs:label "Trade Size" ;
    rdfs:comment """Number of shares in a trade. Stored as Float64 because
        the compactor infers from JSON (which has no integer type).""" ;
    mnf:requiredPhysicalType mnf:Double ;
    mnf:valueRange [ mnf:minExclusive 0.0 ] .

pm:ShareAmount a mnf:SemanticType ;
    rdfs:label "Share Amount Held" ;
    rdfs:comment "Number of shares held by a position holder." ;
    mnf:requiredPhysicalType mnf:Double ;
    mnf:valueRange [ mnf:minExclusive 0.0 ] .

# --- Temporal ---

pm:FetchTimestamp a mnf:SemanticType ;
    rdfs:label "Fetch Timestamp" ;
    rdfs:comment """Unix epoch float (seconds since 1970-01-01T00:00:00Z)
        injected by the fetcher at collection time. NOT from the API.
        Stored as Float64, not TimestampTZ, because the fetcher writes
        time.time() directly.""" ;
    mnf:requiredPhysicalType mnf:Double .

pm:ISOTimestamp a mnf:SemanticType ;
    rdfs:label "ISO 8601 Timestamp String" ;
    rdfs:comment """ISO 8601 formatted timestamp as a string. Used by the
        Gamma API for dates (startDate, endDate, createdAt, etc.).""" ;
    mnf:requiredPhysicalType mnf:Varchar .

# --- Categorical ---
# [MNF-GAP-2]: These types have constrained string values but Manifest can only
# express numeric ranges via mnf:valueRange.

pm:TradeSide a mnf:SemanticType ;
    rdfs:label "Trade Side" ;
    rdfs:comment """Direction of a trade: "BUY" or "SELL".""" ;
    mnf:requiredPhysicalType mnf:Varchar ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        mnf:allowedValue "BUY" ;
        mnf:allowedValue "SELL"
    ] .

pm:OutcomeIndex a mnf:SemanticType ;
    rdfs:label "Outcome Index" ;
    rdfs:comment """Zero-based index into a market's outcome array.
        Typically 0 or 1 for binary Yes/No markets.""" ;
    mnf:requiredPhysicalType mnf:Double ;
    mnf:valueRange [ mnf:minInclusive 0 ] .

pm:MarketCategory a mnf:SemanticType ;
    rdfs:label "Market Category" ;
    rdfs:comment """Category label for a market (e.g. 'Politics', 'Sports',
        'Crypto'). Open-ended but constrained set from the platform.""" ;
    mnf:requiredPhysicalType mnf:Varchar ;
    mnf:hasAllowedValues [
        a mnf:AllowedValues ;
        rdfs:comment """Representative values — not exhaustive. Polymarket
            may add new categories at any time.""" ;
        mnf:allowedValue "Politics" ;
        mnf:allowedValue "Sports" ;
        mnf:allowedValue "Crypto" ;
        mnf:allowedValue "Pop Culture" ;
        mnf:allowedValue "Business" ;
        mnf:allowedValue "Science"
    ] .

# --- Scores ---

pm:CompetitivenessScore a mnf:SemanticType ;
    rdfs:label "Market Competitiveness Score" ;
    rdfs:comment "Score from 0.0 to 1.0 indicating how competitive a market is." ;
    mnf:requiredPhysicalType mnf:Double ;
    mnf:valueRange [
        mnf:minInclusive 0.0 ;
        mnf:maxInclusive 1.0
    ] .

# --- Embedded JSON ---
# [MNF-GAP-3]: Physical type is Varchar but content is a JSON array.

pm:JSONArray a mnf:SemanticType ;
    rdfs:label "JSON-Serialized Array" ;
    rdfs:comment """A column whose physical type is Varchar but whose content
        is a JSON-encoded array. Examples: outcomes='["Yes","No"]',
        clobTokenIds='["1234","5678"]', bids/asks orderbook levels.
        Columns with this type should also declare mnf:embeddedStructure
        for the inner element type.""" ;
    mnf:requiredPhysicalType mnf:Varchar .

# --- System-injected metadata ---

pm:DataSourceLabel a mnf:SemanticType ;
    rdfs:label "Data Source Label" ;
    rdfs:comment """Label identifying which fetcher stream produced this row
        (e.g. 'gamma/markets', 'clob/prices'). Injected by the fetcher,
        not from the API.""" ;
    mnf:requiredPhysicalType mnf:Varchar .


# =============================================================================
# PART 2: Datasets and Schemas
# =============================================================================


# -----------------------------------------------------------------------------
# 2a. MarketSnapshots (gamma/markets)
# -----------------------------------------------------------------------------

pm:MarketSnapshots a mnf:Dataset ;
    rdfs:label "Gamma Market Snapshots" ;
    rdfs:comment """Hourly snapshots of all active Polymarket markets from
        the Gamma API. ~33,500 markets per snapshot, polled every 5 minutes,
        compacted hourly. Richest schema (~30+ columns).""" ;

    mnf:rowSemantics mnf:SnapshotRow ;
    mnf:entityKey pm:mkt_id ;
    mnf:snapshotTimestamp pm:mkt_fetched_at ;
    mnf:schemaStability mnf:InferredSchema ;

    mnf:hasColumn
        pm:mkt_fetched_at ,
        pm:mkt_source ,
        pm:mkt_id ,
        pm:mkt_question ,
        pm:mkt_condition_id ,
        pm:mkt_slug ,
        pm:mkt_outcomes ,
        pm:mkt_outcome_prices ,
        pm:mkt_clob_token_ids ,
        pm:mkt_volume ,
        pm:mkt_volume_num ,
        pm:mkt_volume_24hr ,
        pm:mkt_volume_1wk ,
        pm:mkt_volume_1mo ,
        pm:mkt_volume_1yr ,
        pm:mkt_liquidity ,
        pm:mkt_liquidity_num ,
        pm:mkt_active ,
        pm:mkt_closed ,
        pm:mkt_start_date ,
        pm:mkt_end_date ,
        pm:mkt_created_at ,
        pm:mkt_updated_at ,
        pm:mkt_last_trade_price ,
        pm:mkt_best_bid ,
        pm:mkt_best_ask ,
        pm:mkt_spread ,
        pm:mkt_one_day_price_change ,
        pm:mkt_one_week_price_change ,
        pm:mkt_neg_risk ,
        pm:mkt_enable_order_book ,
        pm:mkt_competitive ,
        pm:mkt_rewards_min_size ,
        pm:mkt_rewards_max_spread ,
        pm:mkt_category ,
        pm:mkt_image ,
        pm:mkt_description ;

    mnf:hasPhysicalLayout pm:snapshot_layout ;
    mnf:partitionedBy pm:hourly_hive_partition ;
    mnf:hasProvenance pm:polymarket_provenance ;
    mnf:hasKnownDeficiency
        pm:deficiency_schema_inferred ,
        pm:deficiency_snapshot_dedup ,
        pm:deficiency_json_in_strings .


# --- Market column definitions ---

pm:mkt_fetched_at a mnf:Column ;
    mnf:columnName "_fetched_at" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType pm:FetchTimestamp ;
    mnf:nullable false ;
    rdfs:comment "Injected by fetcher, not from API." .

pm:mkt_source a mnf:Column ;
    mnf:columnName "_source" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:DataSourceLabel ;
    mnf:nullable false ;
    rdfs:comment "Always 'gamma/markets'. Injected by fetcher." .

pm:mkt_id a mnf:Column ;
    mnf:columnName "id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:MarketId ;
    mnf:nullable false ;
    rdfs:comment "Primary entity key — same market ID repeats across snapshots." .

pm:mkt_question a mnf:Column ;
    mnf:columnName "question" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "The market question text, e.g. 'Will X happen by Y date?'" .

pm:mkt_condition_id a mnf:Column ;
    mnf:columnName "conditionId" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:ConditionId ;
    mnf:nullable true ;
    rdfs:comment """On-chain condition ID. Cross-references trades and holders.
        See pm:fk_trades_to_markets, pm:fk_holders_to_markets, and
        pm:same_entity_condition_id for formal relationships.""" .

pm:mkt_slug a mnf:Column ;
    mnf:columnName "slug" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:Slug ;
    mnf:nullable true .

pm:mkt_outcomes a mnf:Column ;
    mnf:columnName "outcomes" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:JSONArray ;
    mnf:nullable true ;
    rdfs:comment "JSON-encoded array of outcome labels, e.g. '[\"Yes\",\"No\"]'." ;
    mnf:embeddedStructure [
        a mnf:EmbeddedStructure ;
        mnf:embeddedFormat mnf:JSONEncoding ;
        mnf:embeddedElementType "array<string>"
    ] .

pm:mkt_outcome_prices a mnf:Column ;
    mnf:columnName "outcomePrices" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:JSONArray ;
    mnf:nullable true ;
    rdfs:comment """JSON-encoded array of probability floats, e.g. '[\"0.65\",\"0.35\"]'.
        Prices encoded as strings within a JSON array within a string
        column — triple indirection.""" ;
    mnf:embeddedStructure [
        a mnf:EmbeddedStructure ;
        mnf:embeddedFormat mnf:JSONEncoding ;
        mnf:embeddedElementType "array<string>" ;
        rdfs:comment "Inner strings are probability floats (0.0-1.0)."
    ] .

pm:mkt_clob_token_ids a mnf:Column ;
    mnf:columnName "clobTokenIds" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:JSONArray ;
    mnf:nullable true ;
    rdfs:comment """JSON-encoded array of CLOB token IDs for this market's
        outcomes. Links to clob/prices.token_id and clob/books.asset_id.""" ;
    mnf:embeddedStructure [
        a mnf:EmbeddedStructure ;
        mnf:embeddedFormat mnf:JSONEncoding ;
        mnf:embeddedElementType "array<string>" ;
        rdfs:comment "Inner strings are CLOBTokenId values."
    ] .

pm:mkt_volume a mnf:Column ;
    mnf:columnName "volume" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment """Total volume as a string. The API returns this as a string;
        Polars infers Varchar. See volumeNum for the numeric version.""" .

pm:mkt_volume_num a mnf:Column ;
    mnf:columnName "volumeNum" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType pm:USDAmount ;
    mnf:nullable true ;
    rdfs:comment "Numeric total trading volume in USD." .

pm:mkt_volume_24hr a mnf:Column ;
    mnf:columnName "volume24hr" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType pm:USDAmount ;
    mnf:nullable true .

pm:mkt_volume_1wk a mnf:Column ;
    mnf:columnName "volume1wk" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType pm:USDAmount ;
    mnf:nullable true .

pm:mkt_volume_1mo a mnf:Column ;
    mnf:columnName "volume1mo" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType pm:USDAmount ;
    mnf:nullable true .

pm:mkt_volume_1yr a mnf:Column ;
    mnf:columnName "volume1yr" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType pm:USDAmount ;
    mnf:nullable true .

pm:mkt_liquidity a mnf:Column ;
    mnf:columnName "liquidity" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "Liquidity as string from API. See liquidityNum for numeric." .

pm:mkt_liquidity_num a mnf:Column ;
    mnf:columnName "liquidityNum" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType pm:USDAmount ;
    mnf:nullable true .

pm:mkt_active a mnf:Column ;
    mnf:columnName "active" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment """Boolean indicating market is active. Stored as Varchar
        because Polars infers from JSON — may be 'true'/'false' string
        or actual boolean depending on inference.""" .

pm:mkt_closed a mnf:Column ;
    mnf:columnName "closed" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "Whether the market has been resolved." .

pm:mkt_start_date a mnf:Column ;
    mnf:columnName "startDate" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:ISOTimestamp ;
    mnf:nullable true .

pm:mkt_end_date a mnf:Column ;
    mnf:columnName "endDate" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:ISOTimestamp ;
    mnf:nullable true .

pm:mkt_created_at a mnf:Column ;
    mnf:columnName "createdAt" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:ISOTimestamp ;
    mnf:nullable true .

pm:mkt_updated_at a mnf:Column ;
    mnf:columnName "updatedAt" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:ISOTimestamp ;
    mnf:nullable true .

pm:mkt_last_trade_price a mnf:Column ;
    mnf:columnName "lastTradePrice" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType pm:Probability ;
    mnf:nullable true .

pm:mkt_best_bid a mnf:Column ;
    mnf:columnName "bestBid" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType pm:Probability ;
    mnf:nullable true .

pm:mkt_best_ask a mnf:Column ;
    mnf:columnName "bestAsk" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType pm:Probability ;
    mnf:nullable true .

pm:mkt_spread a mnf:Column ;
    mnf:columnName "spread" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType pm:PriceSpread ;
    mnf:nullable true ;
    rdfs:comment "Derived: bestAsk - bestBid." .

pm:mkt_one_day_price_change a mnf:Column ;
    mnf:columnName "oneDayPriceChange" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType pm:PriceChange ;
    mnf:nullable true .

pm:mkt_one_week_price_change a mnf:Column ;
    mnf:columnName "oneWeekPriceChange" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType pm:PriceChange ;
    mnf:nullable true .

pm:mkt_neg_risk a mnf:Column ;
    mnf:columnName "negRisk" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "Negative risk model flag. Boolean stored as inferred type." .

pm:mkt_enable_order_book a mnf:Column ;
    mnf:columnName "enableOrderBook" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "Whether CLOB trading is enabled for this market." .

pm:mkt_competitive a mnf:Column ;
    mnf:columnName "competitive" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType pm:CompetitivenessScore ;
    mnf:nullable true .

pm:mkt_rewards_min_size a mnf:Column ;
    mnf:columnName "rewardsMinSize" ;
    mnf:physicalType mnf:Double ;
    mnf:nullable true ;
    rdfs:comment "Minimum order size to qualify for liquidity rewards." .

pm:mkt_rewards_max_spread a mnf:Column ;
    mnf:columnName "rewardsMaxSpread" ;
    mnf:physicalType mnf:Double ;
    mnf:nullable true ;
    rdfs:comment "Maximum spread to qualify for liquidity rewards." .

pm:mkt_category a mnf:Column ;
    mnf:columnName "category" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:MarketCategory ;
    mnf:nullable true ;
    rdfs:comment "Market category — see pm:MarketCategory for allowed values." .

pm:mkt_image a mnf:Column ;
    mnf:columnName "image" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "Market image URL." .

pm:mkt_description a mnf:Column ;
    mnf:columnName "description" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "Full market description text." .


# -----------------------------------------------------------------------------
# 2b. EventSnapshots (gamma/events)
# -----------------------------------------------------------------------------

pm:EventSnapshots a mnf:Dataset ;
    rdfs:label "Gamma Event Snapshots" ;
    rdfs:comment """Hourly snapshots of Polymarket events from the Gamma API.
        ~7,900 events per snapshot. Each event groups one or more related
        markets.""" ;

    mnf:rowSemantics mnf:SnapshotRow ;
    mnf:entityKey pm:evt_id ;
    mnf:snapshotTimestamp pm:evt_fetched_at ;
    mnf:schemaStability mnf:InferredSchema ;

    mnf:hasColumn
        pm:evt_fetched_at ,
        pm:evt_source ,
        pm:evt_id ,
        pm:evt_title ,
        pm:evt_slug ,
        pm:evt_description ,
        pm:evt_active ,
        pm:evt_closed ,
        pm:evt_volume ,
        pm:evt_volume_24hr ,
        pm:evt_liquidity ,
        pm:evt_open_interest ,
        pm:evt_start_date ,
        pm:evt_end_date ,
        pm:evt_competitive ,
        pm:evt_comment_count ,
        pm:evt_neg_risk ,
        pm:evt_markets ,
        pm:evt_tags ;

    mnf:hasPhysicalLayout pm:snapshot_layout ;
    mnf:partitionedBy pm:hourly_hive_partition ;
    mnf:hasProvenance pm:polymarket_provenance ;
    mnf:hasKnownDeficiency
        pm:deficiency_schema_inferred ,
        pm:deficiency_snapshot_dedup .


# --- Event column definitions ---

pm:evt_fetched_at a mnf:Column ;
    mnf:columnName "_fetched_at" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType pm:FetchTimestamp ;
    mnf:nullable false .

pm:evt_source a mnf:Column ;
    mnf:columnName "_source" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:DataSourceLabel ;
    mnf:nullable false .

pm:evt_id a mnf:Column ;
    mnf:columnName "id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:EventId ;
    mnf:nullable false ;
    rdfs:comment "Entity key for snapshot semantics." .

pm:evt_title a mnf:Column ;
    mnf:columnName "title" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true .

pm:evt_slug a mnf:Column ;
    mnf:columnName "slug" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:Slug ;
    mnf:nullable true .

pm:evt_description a mnf:Column ;
    mnf:columnName "description" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true .

pm:evt_active a mnf:Column ;
    mnf:columnName "active" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true .

pm:evt_closed a mnf:Column ;
    mnf:columnName "closed" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true .

pm:evt_volume a mnf:Column ;
    mnf:columnName "volume" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType pm:USDAmount ;
    mnf:nullable true .

pm:evt_volume_24hr a mnf:Column ;
    mnf:columnName "volume24hr" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType pm:USDAmount ;
    mnf:nullable true .

pm:evt_liquidity a mnf:Column ;
    mnf:columnName "liquidity" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType pm:USDAmount ;
    mnf:nullable true .

pm:evt_open_interest a mnf:Column ;
    mnf:columnName "openInterest" ;
    mnf:physicalType mnf:Double ;
    mnf:nullable true ;
    rdfs:comment "Open interest count. Double because Polars infers from JSON." .

pm:evt_start_date a mnf:Column ;
    mnf:columnName "startDate" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:ISOTimestamp ;
    mnf:nullable true .

pm:evt_end_date a mnf:Column ;
    mnf:columnName "endDate" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:ISOTimestamp ;
    mnf:nullable true .

pm:evt_competitive a mnf:Column ;
    mnf:columnName "competitive" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType pm:CompetitivenessScore ;
    mnf:nullable true .

pm:evt_comment_count a mnf:Column ;
    mnf:columnName "commentCount" ;
    mnf:physicalType mnf:Double ;
    mnf:nullable true .

pm:evt_neg_risk a mnf:Column ;
    mnf:columnName "negRisk" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true .

pm:evt_markets a mnf:Column ;
    mnf:columnName "markets" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment """JSON-serialized array of nested market objects. Each object
        contains a subset of the gamma/markets fields (~20 fields).""" ;
    mnf:embeddedStructure [
        a mnf:EmbeddedStructure ;
        mnf:embeddedFormat mnf:JSONEncoding ;
        mnf:embeddedElementType "array<{id, question, conditionId, slug, outcomes, volume, ...}>" ;
        rdfs:comment "Each element is a market object mirroring gamma/markets fields."
    ] .

pm:evt_tags a mnf:Column ;
    mnf:columnName "tags" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:JSONArray ;
    mnf:nullable true ;
    rdfs:comment "JSON array of tag objects associated with this event." .


# -----------------------------------------------------------------------------
# 2c. PriceSnapshots (clob/prices)
# -----------------------------------------------------------------------------

pm:PriceSnapshots a mnf:Dataset ;
    rdfs:label "CLOB Price Snapshots" ;
    rdfs:comment """Hourly snapshots of CLOB token prices and midpoints.
        ~2,000 tokens polled every 30 seconds. Merges /price and /midpoint
        endpoints.""" ;

    mnf:rowSemantics mnf:SnapshotRow ;
    mnf:entityKey pm:px_token_id ;
    mnf:snapshotTimestamp pm:px_fetched_at ;
    mnf:schemaStability mnf:InferredSchema ;

    mnf:hasColumn
        pm:px_fetched_at ,
        pm:px_source ,
        pm:px_token_id ,
        pm:px_price ,
        pm:px_midpoint ;

    mnf:hasPhysicalLayout pm:snapshot_layout ;
    mnf:partitionedBy pm:hourly_hive_partition ;
    mnf:hasProvenance pm:polymarket_provenance ;
    mnf:hasKnownDeficiency
        pm:deficiency_schema_inferred ,
        pm:deficiency_mixed_type_price .


# --- Price column definitions ---

pm:px_fetched_at a mnf:Column ;
    mnf:columnName "_fetched_at" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType pm:FetchTimestamp ;
    mnf:nullable false .

pm:px_source a mnf:Column ;
    mnf:columnName "_source" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:DataSourceLabel ;
    mnf:nullable false .

pm:px_token_id a mnf:Column ;
    mnf:columnName "token_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:CLOBTokenId ;
    mnf:nullable false ;
    rdfs:comment """Entity key for snapshot semantics. See
        pm:same_entity_clob_token for cross-dataset identity.""" .

pm:px_price a mnf:Column ;
    mnf:columnName "price" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment """Last trade price. SHOULD be a float (0.0-1.0) but the API
        sometimes returns an error object, causing Polars to infer the
        column as Varchar in those batches. Physical type varies between
        batches: sometimes Float64, sometimes Varchar. See
        pm:deficiency_mixed_type_price.""" .

pm:px_midpoint a mnf:Column ;
    mnf:columnName "midpoint" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "Midpoint between best bid and ask. String because API returns string." .


# -----------------------------------------------------------------------------
# 2d. OrderbookSnapshots (clob/books)
# -----------------------------------------------------------------------------

pm:OrderbookSnapshots a mnf:Dataset ;
    rdfs:label "CLOB Orderbook Snapshots" ;
    rdfs:comment """Hourly snapshots of orderbook state for top 100 active
        tokens. Polled every 2 minutes.""" ;

    mnf:rowSemantics mnf:SnapshotRow ;
    mnf:entityKey pm:ob_asset_id ;
    mnf:snapshotTimestamp pm:ob_fetched_at ;
    mnf:schemaStability mnf:InferredSchema ;

    mnf:hasColumn
        pm:ob_fetched_at ,
        pm:ob_source ,
        pm:ob_asset_id ,
        pm:ob_market ,
        pm:ob_timestamp ,
        pm:ob_hash ,
        pm:ob_bids ,
        pm:ob_asks ,
        pm:ob_last_trade_price ,
        pm:ob_min_order_size ,
        pm:ob_tick_size ,
        pm:ob_neg_risk ;

    mnf:hasPhysicalLayout pm:snapshot_layout ;
    mnf:partitionedBy pm:hourly_hive_partition ;
    mnf:hasProvenance pm:polymarket_provenance ;
    mnf:hasKnownDeficiency
        pm:deficiency_schema_inferred ,
        pm:deficiency_json_in_strings .


# --- Orderbook column definitions ---

pm:ob_fetched_at a mnf:Column ;
    mnf:columnName "_fetched_at" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType pm:FetchTimestamp ;
    mnf:nullable false .

pm:ob_source a mnf:Column ;
    mnf:columnName "_source" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:DataSourceLabel ;
    mnf:nullable false .

pm:ob_asset_id a mnf:Column ;
    mnf:columnName "asset_id" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:CLOBTokenId ;
    mnf:nullable false ;
    rdfs:comment """Entity key for snapshot semantics. See
        pm:same_entity_clob_token for cross-dataset identity.""" .

pm:ob_market a mnf:Column ;
    mnf:columnName "market" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:ConditionId ;
    mnf:nullable true ;
    rdfs:comment "See pm:fk_books_to_markets for formal FK relationship." .

pm:ob_timestamp a mnf:Column ;
    mnf:columnName "timestamp" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "Server timestamp in milliseconds as string." .

pm:ob_hash a mnf:Column ;
    mnf:columnName "hash" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "Orderbook state hash for deduplication." .

pm:ob_bids a mnf:Column ;
    mnf:columnName "bids" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:JSONArray ;
    mnf:nullable true ;
    rdfs:comment """JSON array of bid levels.""" ;
    mnf:embeddedStructure [
        a mnf:EmbeddedStructure ;
        mnf:embeddedFormat mnf:JSONEncoding ;
        mnf:embeddedElementType "array<{price: string, size: string}>"
    ] .

pm:ob_asks a mnf:Column ;
    mnf:columnName "asks" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:JSONArray ;
    mnf:nullable true ;
    rdfs:comment """JSON array of ask levels.""" ;
    mnf:embeddedStructure [
        a mnf:EmbeddedStructure ;
        mnf:embeddedFormat mnf:JSONEncoding ;
        mnf:embeddedElementType "array<{price: string, size: string}>"
    ] .

pm:ob_last_trade_price a mnf:Column ;
    mnf:columnName "last_trade_price" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "String representation of last trade price." .

pm:ob_min_order_size a mnf:Column ;
    mnf:columnName "min_order_size" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true .

pm:ob_tick_size a mnf:Column ;
    mnf:columnName "tick_size" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true .

pm:ob_neg_risk a mnf:Column ;
    mnf:columnName "neg_risk" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true .


# -----------------------------------------------------------------------------
# 2e. Trades (data_api/trades)
# -----------------------------------------------------------------------------
# Most event-like dataset — closest analogue to AIS broadcasts.

pm:Trades a mnf:Dataset ;
    rdfs:label "Trade Events" ;
    rdfs:comment """Hourly files of recent trades from the Data API. 100 trades
        polled every 60 seconds. This is the most event-like dataset —
        each row represents a distinct trade event, unlike the snapshot
        datasets. Rows are in API response order (roughly reverse
        chronological), not meaningfully sorted.""" ;

    mnf:rowSemantics mnf:EventRow ;
    mnf:schemaStability mnf:InferredSchema ;

    mnf:hasColumn
        pm:tr_fetched_at ,
        pm:tr_source ,
        pm:tr_proxy_wallet ,
        pm:tr_side ,
        pm:tr_asset ,
        pm:tr_condition_id ,
        pm:tr_size ,
        pm:tr_price ,
        pm:tr_timestamp ,
        pm:tr_title ,
        pm:tr_slug ,
        pm:tr_event_slug ,
        pm:tr_outcome ,
        pm:tr_outcome_index ,
        pm:tr_name ,
        pm:tr_pseudonym ,
        pm:tr_transaction_hash ,
        pm:tr_icon ,
        pm:tr_bio ,
        pm:tr_profile_image ;

    mnf:hasPhysicalLayout pm:snapshot_layout ;
    mnf:partitionedBy pm:hourly_hive_partition ;
    mnf:hasProvenance pm:polymarket_provenance ;
    mnf:hasKnownDeficiency
        pm:deficiency_schema_inferred ,
        pm:deficiency_duplicate_trades .


# --- Trade column definitions ---

pm:tr_fetched_at a mnf:Column ;
    mnf:columnName "_fetched_at" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType pm:FetchTimestamp ;
    mnf:nullable false .

pm:tr_source a mnf:Column ;
    mnf:columnName "_source" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:DataSourceLabel ;
    mnf:nullable false .

pm:tr_proxy_wallet a mnf:Column ;
    mnf:columnName "proxyWallet" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:ProxyWallet ;
    mnf:nullable true .

pm:tr_side a mnf:Column ;
    mnf:columnName "side" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:TradeSide ;
    mnf:nullable true ;
    rdfs:comment "See pm:TradeSide for allowed values." .

pm:tr_asset a mnf:Column ;
    mnf:columnName "asset" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:CLOBTokenId ;
    mnf:nullable true ;
    rdfs:comment "See pm:fk_trades_to_prices for formal FK relationship." .

pm:tr_condition_id a mnf:Column ;
    mnf:columnName "conditionId" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:ConditionId ;
    mnf:nullable true ;
    rdfs:comment "See pm:fk_trades_to_markets and pm:same_entity_condition_id." .

pm:tr_size a mnf:Column ;
    mnf:columnName "size" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType pm:TradeSize ;
    mnf:nullable true .

pm:tr_price a mnf:Column ;
    mnf:columnName "price" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType pm:Probability ;
    mnf:nullable true .

pm:tr_timestamp a mnf:Column ;
    mnf:columnName "timestamp" ;
    mnf:physicalType mnf:Double ;
    mnf:nullable true ;
    rdfs:comment "Unix timestamp of the trade. Double because JSON-inferred." .

pm:tr_title a mnf:Column ;
    mnf:columnName "title" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "Denormalized market title from the trade response." .

pm:tr_slug a mnf:Column ;
    mnf:columnName "slug" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:Slug ;
    mnf:nullable true .

pm:tr_event_slug a mnf:Column ;
    mnf:columnName "eventSlug" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType pm:Slug ;
    mnf:nullable true .

pm:tr_outcome a mnf:Column ;
    mnf:columnName "outcome" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
    rdfs:comment "Outcome label (e.g. 'Yes', 'No'). Values vary per market." .

pm:tr_outcome_index a mnf:Column ;
    mnf:columnName "outcomeIndex" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType pm:OutcomeIndex ;
    mnf:nullable true .

pm:tr_name a mnf:Column ;
    mnf:columnName "name" ;
    mnf:physicalType mnf:Varchar ;
    mnf:nullable true ;
