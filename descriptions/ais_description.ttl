@prefix sdl:    <http://example.org/sdl#> .
@prefix ais:    <http://example.org/ais#> .
@prefix geo:    <http://www.opengis.net/ont/geosparql#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# AIS-NOAA Dataset Description
# =============================================================================
#
# Applies the SDL vocabulary to describe the preprocessed NOAA Marine Cadastre
# AIS data: daily broadcast files and their companion daily index files.
#
# This serves as the reference example for the SDL framework.
# =============================================================================


# =============================================================================
# PART 1: AIS Domain Semantic Types
# =============================================================================
#
# These are the opaque leaves — domain-specific types that carry meaning
# beyond what the physical storage type tells you. Each declares its
# required physical type, value constraints, and domain semantics.
# =============================================================================

ais:MMSI a sdl:SemanticType ;
    rdfs:label "Maritime Mobile Service Identity" ;
    rdfs:comment """Nine-digit vessel identifier assigned by flag state. In
        practice: not unique to a vessel (vessels change MMSI, multiple
        vessels sometimes share one, some are garbage). Treat as 'mostly
        identifies a vessel, with known failure modes'.""" ;
    sdl:requiredPhysicalType sdl:Integer ;
    sdl:valueRange [
        sdl:minInclusive 100000000 ;
        sdl:maxInclusive 799999999
    ] ;
    sdl:computationalProfile sdl:SchemaCheckOnly ;
    rdfs:seeAlso <https://www.itu.int/rec/R-REC-M.585/en> .

ais:IMONumber a sdl:SemanticType ;
    rdfs:label "IMO Ship Identification Number" ;
    rdfs:comment """Seven-digit number permanently assigned to a vessel.
        More reliable than MMSI for identity, but not always present in
        AIS data. String because leading 'IMO' prefix is sometimes
        included.""" ;
    sdl:requiredPhysicalType sdl:Varchar .

ais:WGS84Latitude a sdl:SemanticType ;
    rdfs:label "WGS84 Latitude" ;
    sdl:requiredPhysicalType sdl:Double ;
    sdl:unit "degrees" ;
    sdl:valueRange [
        sdl:minInclusive -90.0 ;
        sdl:maxInclusive  90.0
    ] .

ais:WGS84Longitude a sdl:SemanticType ;
    rdfs:label "WGS84 Longitude" ;
    sdl:requiredPhysicalType sdl:Double ;
    sdl:unit "degrees" ;
    sdl:valueRange [
        sdl:minInclusive -180.0 ;
        sdl:maxInclusive  180.0
    ] .

ais:WGS84CoordinatePair a sdl:SemanticType ;
    rdfs:label "WGS84 Coordinate Pair (lat, lon)" ;
    rdfs:comment "A pair of columns jointly representing a WGS84 position." .

ais:SpeedOverGround a sdl:SemanticType ;
    rdfs:label "Speed Over Ground" ;
    sdl:requiredPhysicalType sdl:Double ;
    sdl:unit "knots" ;
    sdl:valueRange [
        sdl:minInclusive 0.0 ;
        sdl:maxInclusive 102.2
    ] ;
    rdfs:comment """AIS SOG: 0.0-102.2 knots in 0.1 knot steps. Value 102.3
        means >=102.2. Null or NaN means not available.""" .

ais:CourseOverGround a sdl:SemanticType ;
    rdfs:label "Course Over Ground" ;
    sdl:requiredPhysicalType sdl:Double ;
    sdl:unit "degrees" ;
    sdl:valueRange [
        sdl:minInclusive 0.0 ;
        sdl:maxExclusive 360.0
    ] ;
    rdfs:comment "Relative to true north. 3600 (36.0 scaled) = not available." .

ais:TrueHeading a sdl:SemanticType ;
    rdfs:label "True Heading" ;
    sdl:requiredPhysicalType sdl:Double ;
    sdl:unit "degrees" ;
    sdl:valueRange [
        sdl:minInclusive 0.0 ;
        sdl:maxExclusive 360.0
    ] ;
    rdfs:comment "511 means not available in raw AIS; may appear as NaN here." .

ais:VesselTypeCode a sdl:SemanticType ;
    rdfs:label "AIS Vessel Type Code" ;
    sdl:requiredPhysicalType sdl:Integer ;
    rdfs:comment """Vessel type as per ITU-R M.1371. Values 0-99. Grouped:
        30-39 fishing, 40-49 HSC, 60-69 passenger, 70-79 cargo,
        80-89 tanker, etc.""" ;
    sdl:valueRange [
        sdl:minInclusive 0 ;
        sdl:maxInclusive 99
    ] .

ais:NavigationalStatus a sdl:SemanticType ;
    rdfs:label "AIS Navigational Status" ;
    sdl:requiredPhysicalType sdl:Integer ;
    rdfs:comment """0=under way using engine, 1=at anchor, 2=not under command,
        3=restricted maneuverability, 5=moored, 7=fishing, 8=under sail,
        15=default/not defined. Per ITU-R M.1371.""" ;
    sdl:valueRange [
        sdl:minInclusive 0 ;
        sdl:maxInclusive 15
    ] .

ais:VesselDraft a sdl:SemanticType ;
    rdfs:label "Vessel Static Draft" ;
    sdl:requiredPhysicalType sdl:Double ;
    sdl:unit "metres" ;
    sdl:valueRange [
        sdl:minInclusive 0.0 ;
        sdl:maxInclusive 25.5
    ] ;
    rdfs:comment "Maximum draught. 0 = not available in raw AIS." .

ais:VesselLength a sdl:SemanticType ;
    rdfs:label "Vessel Length" ;
    sdl:requiredPhysicalType sdl:Double ;
    sdl:unit "metres" .

ais:VesselWidth a sdl:SemanticType ;
    rdfs:label "Vessel Width (Beam)" ;
    sdl:requiredPhysicalType sdl:Double ;
    sdl:unit "metres" .

ais:CargoTypeCode a sdl:SemanticType ;
    rdfs:label "AIS Cargo Type Code" ;
    sdl:requiredPhysicalType sdl:Integer .

ais:CallSign a sdl:SemanticType ;
    rdfs:label "Radio Call Sign" ;
    sdl:requiredPhysicalType sdl:Varchar .

ais:VesselName a sdl:SemanticType ;
    rdfs:label "Vessel Name" ;
    sdl:requiredPhysicalType sdl:Varchar ;
    rdfs:comment """As broadcast by AIS. May contain trailing spaces, be
        truncated, or vary between broadcasts.""" .

ais:TransceiverClass a sdl:SemanticType ;
    rdfs:label "AIS Transceiver Class" ;
    sdl:requiredPhysicalType sdl:Varchar ;
    rdfs:comment "E.g. 'A', 'B', 'A-S'." .

ais:WKBPoint a sdl:SemanticType ;
    rdfs:label "Well-Known Binary Point Geometry" ;
    sdl:requiredPhysicalType sdl:Blob ;
    rdfs:comment "WKB-encoded Point geometry. CRS: WGS84 / EPSG:4326." .

ais:H3CellIndex a sdl:SemanticType ;
    rdfs:label "H3 Hexagonal Cell Index" ;
    sdl:requiredPhysicalType sdl:UBigInt ;
    rdfs:comment "Uber H3 cell index at a declared resolution." .

ais:H3Resolution15 a sdl:SemanticType ;
    rdfs:label "H3 Cell Index at Resolution 15" ;
    rdfs:comment "~0.9 m² cell area. Finest H3 resolution." ;
    # inherits from ais:H3CellIndex conceptually
    sdl:requiredPhysicalType sdl:UBigInt .

ais:AISTimestamp a sdl:SemanticType ;
    rdfs:label "AIS Broadcast Timestamp" ;
    sdl:requiredPhysicalType sdl:TimestampTZ ;
    rdfs:comment "Timestamp of the AIS broadcast, with timezone (UTC)." .

ais:AISRawTimestampString a sdl:SemanticType ;
    rdfs:label "Raw AIS Timestamp String" ;
    sdl:requiredPhysicalType sdl:Varchar ;
    rdfs:comment """Original timestamp string from the NOAA CSV before parsing.
        Retained for traceability.""" .

ais:PartitionDate a sdl:SemanticType ;
    rdfs:label "Partition Date" ;
    sdl:requiredPhysicalType sdl:Date ;
    rdfs:comment """Date value constant within each file, matching the file's
        partition. Embedded as a column for query convenience.""" .

ais:DistanceMetres a sdl:SemanticType ;
    rdfs:label "Distance in Metres" ;
    sdl:requiredPhysicalType sdl:Double ;
    sdl:unit "metres" ;
    sdl:valueRange [ sdl:minInclusive 0.0 ] .

ais:DurationSeconds a sdl:SemanticType ;
    rdfs:label "Duration in Seconds" ;
    sdl:requiredPhysicalType sdl:Double ;
    sdl:unit "seconds" ;
    sdl:valueRange [ sdl:minInclusive 0.0 ] .

ais:SpeedMetresPerSecond a sdl:SemanticType ;
    rdfs:label "Speed in Metres per Second" ;
    sdl:requiredPhysicalType sdl:Double ;
    sdl:unit "m/s" ;
    sdl:valueRange [ sdl:minInclusive 0.0 ] .

ais:MessageCount a sdl:SemanticType ;
    rdfs:label "Count of AIS Messages" ;
    sdl:requiredPhysicalType sdl:BigInt ;
    sdl:valueRange [ sdl:minInclusive 1 ] ;
    rdfs:comment "Must be >= 1 since the group would not exist otherwise." .


# =============================================================================
# PART 2: Datasets and Schemas
# =============================================================================

# -----------------------------------------------------------------------------
# 2a. Daily Broadcasts Dataset
# -----------------------------------------------------------------------------

ais:DailyBroadcasts a sdl:Dataset ;
    rdfs:label "AIS Daily Broadcast Positions" ;
    rdfs:comment """One Parquet file per day containing preprocessed AIS vessel
        position reports from NOAA Marine Cadastre. Denormalized: includes
        static vessel data (name, IMO, dimensions) merged with position
        reports. Ordered by MMSI then timestamp within each file.""" ;
    sdl:rowSemantics sdl:EventRow ;
    sdl:schemaStability sdl:FixedSchema ;

    # --- Columns ---
    sdl:hasColumn
        ais:bc_mmsi ,
        ais:bc_date ,
        ais:bc_base_date_time ,
        ais:bc_latitude ,
        ais:bc_longitude ,
        ais:bc_sog ,
        ais:bc_cog ,
        ais:bc_heading ,
        ais:bc_vessel_name ,
        ais:bc_imo ,
        ais:bc_call_sign ,
        ais:bc_vessel_type ,
        ais:bc_status ,
        ais:bc_length ,
        ais:bc_width ,
        ais:bc_draft ,
        ais:bc_cargo ,
        ais:bc_transceiver ,
        ais:bc_timestamp ,
        ais:bc_geometry ,
        ais:bc_h3_res15 ;

    # --- Column groups ---
    sdl:hasColumnGroup ais:bc_position ;

    # --- Physical layout ---
    sdl:hasPhysicalLayout ais:bc_layout ;

    # --- Partition scheme ---
    sdl:partitionedBy ais:daily_date_partition ;

    # --- Provenance ---
    sdl:hasProvenance ais:noaa_provenance ;

    # --- Known deficiencies ---
    sdl:hasKnownDeficiency
        ais:deficiency_missing_positions ,
        ais:deficiency_denormalized ,
        ais:deficiency_mmsi_identity .


# --- Broadcast column definitions ---

ais:bc_mmsi a sdl:Column ;
    sdl:columnName "mmsi" ;
    sdl:physicalType sdl:Integer ;
    sdl:semanticType ais:MMSI ;
    sdl:nullable true .

ais:bc_date a sdl:Column ;
    sdl:columnName "date" ;
    sdl:physicalType sdl:Date ;
    sdl:semanticType ais:PartitionDate ;
    sdl:nullable true .

ais:bc_base_date_time a sdl:Column ;
    sdl:columnName "base_date_time" ;
    sdl:physicalType sdl:Varchar ;
    sdl:semanticType ais:AISRawTimestampString ;
    sdl:nullable true .

ais:bc_latitude a sdl:Column ;
    sdl:columnName "latitude" ;
    sdl:physicalType sdl:Double ;
    sdl:semanticType ais:WGS84Latitude ;
    sdl:nullable true .

ais:bc_longitude a sdl:Column ;
    sdl:columnName "longitude" ;
    sdl:physicalType sdl:Double ;
    sdl:semanticType ais:WGS84Longitude ;
    sdl:nullable true .

ais:bc_sog a sdl:Column ;
    sdl:columnName "sog" ;
    sdl:physicalType sdl:Double ;
    sdl:semanticType ais:SpeedOverGround ;
    sdl:nullable true .

ais:bc_cog a sdl:Column ;
    sdl:columnName "cog" ;
    sdl:physicalType sdl:Double ;
    sdl:semanticType ais:CourseOverGround ;
    sdl:nullable true .

ais:bc_heading a sdl:Column ;
    sdl:columnName "heading" ;
    sdl:physicalType sdl:Double ;
    sdl:semanticType ais:TrueHeading ;
    sdl:nullable true .

ais:bc_vessel_name a sdl:Column ;
    sdl:columnName "vessel_name" ;
    sdl:physicalType sdl:Varchar ;
    sdl:semanticType ais:VesselName ;
    sdl:nullable true .

ais:bc_imo a sdl:Column ;
    sdl:columnName "imo" ;
    sdl:physicalType sdl:Varchar ;
    sdl:semanticType ais:IMONumber ;
    sdl:nullable true .

ais:bc_call_sign a sdl:Column ;
    sdl:columnName "call_sign" ;
    sdl:physicalType sdl:Varchar ;
    sdl:semanticType ais:CallSign ;
    sdl:nullable true .

ais:bc_vessel_type a sdl:Column ;
    sdl:columnName "vessel_type" ;
    sdl:physicalType sdl:Integer ;
    sdl:semanticType ais:VesselTypeCode ;
    sdl:nullable true .

ais:bc_status a sdl:Column ;
    sdl:columnName "status" ;
    sdl:physicalType sdl:Integer ;
    sdl:semanticType ais:NavigationalStatus ;
    sdl:nullable true .

ais:bc_length a sdl:Column ;
    sdl:columnName "length" ;
    sdl:physicalType sdl:Double ;
    sdl:semanticType ais:VesselLength ;
    sdl:nullable true .

ais:bc_width a sdl:Column ;
    sdl:columnName "width" ;
    sdl:physicalType sdl:Double ;
    sdl:semanticType ais:VesselWidth ;
    sdl:nullable true .

ais:bc_draft a sdl:Column ;
    sdl:columnName "draft" ;
    sdl:physicalType sdl:Double ;
    sdl:semanticType ais:VesselDraft ;
    sdl:nullable true .

ais:bc_cargo a sdl:Column ;
    sdl:columnName "cargo" ;
    sdl:physicalType sdl:Integer ;
    sdl:semanticType ais:CargoTypeCode ;
    sdl:nullable true .

ais:bc_transceiver a sdl:Column ;
    sdl:columnName "transceiver" ;
    sdl:physicalType sdl:Varchar ;
    sdl:semanticType ais:TransceiverClass ;
    sdl:nullable true .

ais:bc_timestamp a sdl:Column ;
    sdl:columnName "timestamp" ;
    sdl:physicalType sdl:TimestampTZ ;
    sdl:semanticType ais:AISTimestamp ;
    sdl:nullable true .

ais:bc_geometry a sdl:Column ;
    sdl:columnName "geometry" ;
    sdl:physicalType sdl:Blob ;
    sdl:semanticType ais:WKBPoint ;
    sdl:nullable true .

ais:bc_h3_res15 a sdl:Column ;
    sdl:columnName "h3_res15" ;
    sdl:physicalType sdl:UBigInt ;
    sdl:semanticType ais:H3Resolution15 ;
    sdl:nullable true .


# --- Coordinate pair column group ---

ais:bc_position a sdl:ColumnGroup ;
    sdl:groupSemanticType ais:WGS84CoordinatePair ;
    sdl:groupMember ais:bc_latitude ;
    sdl:groupMember ais:bc_longitude .

ais:bc_latitude sdl:memberOf ais:bc_position .
ais:bc_longitude sdl:memberOf ais:bc_position .


# --- Derivations ---

ais:derive_timestamp a sdl:Derivation ;
    rdfs:comment "timestamp is parsed from base_date_time string." ;
    sdl:derivedColumn ais:bc_timestamp ;
    sdl:sourceColumn ais:bc_base_date_time ;
    sdl:derivationFunction ais:ParseTimestamp ;
    sdl:hasDerivationProperty sdl:Deterministic ;
    sdl:hasDerivationProperty sdl:Invertible .

ais:derive_geometry a sdl:Derivation ;
    rdfs:comment "geometry is WKB Point constructed from (latitude, longitude)." ;
    sdl:derivedColumn ais:bc_geometry ;
    sdl:sourceColumn ais:bc_latitude ;
    sdl:sourceColumn ais:bc_longitude ;
    sdl:derivationFunction ais:PointFromWGS84 ;
    sdl:hasDerivationProperty sdl:Deterministic ;
    sdl:hasDerivationProperty sdl:Invertible .

ais:derive_h3 a sdl:Derivation ;
    rdfs:comment "h3_res15 is computed from (latitude, longitude) at resolution 15." ;
    sdl:derivedColumn ais:bc_h3_res15 ;
    sdl:sourceColumn ais:bc_latitude ;
    sdl:sourceColumn ais:bc_longitude ;
    sdl:derivationFunction ais:H3IndexFromWGS84Res15 ;
    sdl:hasDerivationProperty sdl:Deterministic ;
    sdl:hasDerivationProperty sdl:Lossy ;
    rdfs:comment "Lossy: multiple lat/lon pairs map to same H3 cell." .


# --- Physical layout ---

ais:bc_layout a sdl:PhysicalLayout ;
    sdl:fileFormat sdl:Parquet ;
    sdl:hasRowOrdering ais:bc_ordering .

ais:bc_ordering a sdl:RowOrdering ;
    sdl:hasOrderingKey [
        a sdl:OrderingKey ;
        sdl:keyColumn ais:bc_mmsi ;
        sdl:keyDirection sdl:Ascending ;
        sdl:keyPrecedence 1 ;
        sdl:orderingSemantic sdl:ClusteringForIndex ;
        rdfs:comment """Primary sort by MMSI clusters all broadcasts for a
            given vessel contiguously. This enables Parquet row group
            min/max indexes to rapidly skip irrelevant groups when
            filtering by MMSI. The sort direction is arbitrary; the
            clustering is what matters."""
    ] ;
    sdl:hasOrderingKey [
        a sdl:OrderingKey ;
        sdl:keyColumn ais:bc_timestamp ;
        sdl:keyDirection sdl:Ascending ;
        sdl:keyPrecedence 2 ;
        sdl:orderingSemantic sdl:MeaningfulSequence ;
        rdfs:comment """Within each MMSI cluster, broadcasts are in
            chronological order. This ordering is both performance-critical
            (enables timestamp range pruning within a vessel) and
            semantically meaningful (represents the vessel's trajectory
            as a time series)."""
    ] .


# --- Partition scheme ---

ais:daily_date_partition a sdl:PartitionScheme ;
    sdl:partitionColumn ais:bc_date ;
    sdl:partitionGranularity sdl:Daily ;
    sdl:pathTemplate "broadcasts/{year}/ais-{date}.parquet" ;
    sdl:redundantPartitionKey ais:bc_date ;
    rdfs:comment """One file per UTC day. The 'date' column in each file is
        constant and matches the file's date. Path pattern uses ISO date
        format (YYYY-MM-DD) for {date} and four-digit year for {year}.""" .


# --- Constraints on the broadcast dataset ---

ais:bc_date_constant a sdl:DatasetConstraint ;
    sdl:appliesToColumn ais:bc_date ;
    rdfs:label "Date column is constant within each file" ;
    rdfs:comment """Every row in a single Parquet file has the same 'date'
        value, matching the file's partition date.""" ;
    sdl:computationalProfile sdl:FullScanRequired ;
    sdl:validator [
        a sdl:DuckDBValidator ;
        sdl:query "SELECT COUNT(DISTINCT date) = 1 FROM data"
    ] .

ais:bc_timestamp_within_date a sdl:DatasetConstraint ;
    sdl:appliesToColumn ais:bc_timestamp ;
    rdfs:label "All timestamps fall within the partition date (UTC)" ;
    rdfs:comment """The timestamp column values should have a UTC date
        matching the partition date column.""" ;
    sdl:computationalProfile sdl:FullScanRequired .

ais:bc_ordered_within_mmsi a sdl:Constraint ;
    a sdl:Grouped ;
    sdl:groupingColumn ais:bc_mmsi ;
    sdl:innerConstraint [
        a sdl:Ordered ;
        sdl:orderingColumn ais:bc_timestamp ;
        sdl:innerConstraint ais:MonotonicallyNonDecreasing
    ] ;
    rdfs:label "Timestamps non-decreasing within each MMSI group" ;
    sdl:computationalProfile sdl:SequentialScan .

# Leaf constraint: monotonically non-decreasing sequence
ais:MonotonicallyNonDecreasing a sdl:SequenceConstraint ;
    rdfs:label "Values are monotonically non-decreasing" ;
    sdl:computationalProfile sdl:SequentialScan ;
    sdl:validator [
        a sdl:PythonValidator ;
        sdl:module "sdl.validators.sequence" ;
        sdl:function "check_monotonic_nondecreasing"
    ] .


# -----------------------------------------------------------------------------
# 2b. Daily Index Dataset
# -----------------------------------------------------------------------------

ais:DailyIndex a sdl:Dataset ;
    rdfs:label "AIS Daily Vessel Index" ;
    rdfs:comment """One Parquet file per day, one row per MMSI observed that
        day. Summarises the broadcast data for quick vessel-level queries
        across the full time range.""" ;
    sdl:rowSemantics sdl:AggregateRow ;
    sdl:schemaStability sdl:FixedSchema ;

    sdl:hasColumn
        ais:ix_mmsi ,
        ais:ix_date ,
        ais:ix_vessel_names ,
        ais:ix_imos ,
        ais:ix_call_signs ,
        ais:ix_vessel_types ,
        ais:ix_cargos ,
        ais:ix_lengths ,
        ais:ix_widths ,
        ais:ix_drafts ,
        ais:ix_transceiver_classes ,
        ais:ix_message_count ,
        ais:ix_first_timestamp ,
        ais:ix_last_timestamp ,
        ais:ix_duration_s ,
        ais:ix_centroid_lat ,
        ais:ix_centroid_lon ,
        ais:ix_min_lat ,
        ais:ix_max_lat ,
        ais:ix_min_lon ,
        ais:ix_max_lon ,
        ais:ix_distance_m ,
        ais:ix_h3_cell_count ,
        ais:ix_sog_min ,
        ais:ix_sog_max ,
        ais:ix_sog_mean ,
        ais:ix_max_inter_msg_speed_ms ,
        ais:ix_status_codes ;

    sdl:partitionedBy ais:daily_date_partition ;
    sdl:hasPhysicalLayout [
        a sdl:PhysicalLayout ;
        sdl:fileFormat sdl:Parquet
    ] .

# Companion relationship
ais:DailyIndex sdl:companionOf ais:DailyBroadcasts .


# --- Index column definitions (abbreviated: showing types and semantics) ---

ais:ix_mmsi a sdl:Column ;
    sdl:columnName "mmsi" ;
    sdl:physicalType sdl:Integer ;
    sdl:semanticType ais:MMSI .

ais:ix_date a sdl:Column ;
    sdl:columnName "date" ;
    sdl:physicalType sdl:Date ;
    sdl:semanticType ais:PartitionDate .

ais:ix_vessel_names a sdl:Column ;
    sdl:columnName "vessel_names" ;
    sdl:physicalType sdl:VarcharList ;
    rdfs:comment "Distinct vessel names broadcast by this MMSI on this day." .

ais:ix_imos a sdl:Column ;
    sdl:columnName "imos" ;
    sdl:physicalType sdl:VarcharList .

ais:ix_call_signs a sdl:Column ;
    sdl:columnName "call_signs" ;
    sdl:physicalType sdl:VarcharList .

ais:ix_vessel_types a sdl:Column ;
    sdl:columnName "vessel_types" ;
    sdl:physicalType sdl:IntegerList .

ais:ix_cargos a sdl:Column ;
    sdl:columnName "cargos" ;
    sdl:physicalType sdl:IntegerList .

ais:ix_lengths a sdl:Column ;
    sdl:columnName "lengths" ;
    sdl:physicalType sdl:DoubleList .

ais:ix_widths a sdl:Column ;
    sdl:columnName "widths" ;
    sdl:physicalType sdl:DoubleList .

ais:ix_drafts a sdl:Column ;
    sdl:columnName "drafts" ;
    sdl:physicalType sdl:DoubleList .

ais:ix_transceiver_classes a sdl:Column ;
    sdl:columnName "transceiver_classes" ;
    sdl:physicalType sdl:VarcharList .

ais:ix_message_count a sdl:Column ;
    sdl:columnName "message_count" ;
    sdl:physicalType sdl:BigInt ;
    sdl:semanticType ais:MessageCount .

ais:ix_first_timestamp a sdl:Column ;
    sdl:columnName "first_timestamp" ;
    sdl:physicalType sdl:TimestampTZ ;
    sdl:semanticType ais:AISTimestamp .

ais:ix_last_timestamp a sdl:Column ;
    sdl:columnName "last_timestamp" ;
    sdl:physicalType sdl:TimestampTZ ;
    sdl:semanticType ais:AISTimestamp .

ais:ix_duration_s a sdl:Column ;
    sdl:columnName "duration_s" ;
    sdl:physicalType sdl:Double ;
    sdl:semanticType ais:DurationSeconds .

ais:ix_centroid_lat a sdl:Column ;
    sdl:columnName "centroid_lat" ;
    sdl:physicalType sdl:Double ;
    sdl:semanticType ais:WGS84Latitude .

ais:ix_centroid_lon a sdl:Column ;
    sdl:columnName "centroid_lon" ;
    sdl:physicalType sdl:Double ;
    sdl:semanticType ais:WGS84Longitude .

ais:ix_min_lat a sdl:Column ;
    sdl:columnName "min_lat" ;
    sdl:physicalType sdl:Double ;
    sdl:semanticType ais:WGS84Latitude .

ais:ix_max_lat a sdl:Column ;
    sdl:columnName "max_lat" ;
    sdl:physicalType sdl:Double ;
    sdl:semanticType ais:WGS84Latitude .

ais:ix_min_lon a sdl:Column ;
    sdl:columnName "min_lon" ;
    sdl:physicalType sdl:Double ;
    sdl:semanticType ais:WGS84Longitude .

ais:ix_max_lon a sdl:Column ;
    sdl:columnName "max_lon" ;
    sdl:physicalType sdl:Double ;
    sdl:semanticType ais:WGS84Longitude .

ais:ix_distance_m a sdl:Column ;
    sdl:columnName "distance_m" ;
    sdl:physicalType sdl:Double ;
    sdl:semanticType ais:DistanceMetres .

ais:ix_h3_cell_count a sdl:Column ;
    sdl:columnName "h3_cell_count" ;
    sdl:physicalType sdl:BigInt .

ais:ix_sog_min a sdl:Column ;
    sdl:columnName "sog_min" ;
    sdl:physicalType sdl:Double ;
    sdl:semanticType ais:SpeedOverGround .

ais:ix_sog_max a sdl:Column ;
    sdl:columnName "sog_max" ;
    sdl:physicalType sdl:Double ;
    sdl:semanticType ais:SpeedOverGround .

ais:ix_sog_mean a sdl:Column ;
    sdl:columnName "sog_mean" ;
    sdl:physicalType sdl:Double ;
    sdl:semanticType ais:SpeedOverGround .

ais:ix_max_inter_msg_speed_ms a sdl:Column ;
    sdl:columnName "max_inter_msg_speed_ms" ;
    sdl:physicalType sdl:Double ;
    sdl:semanticType ais:SpeedMetresPerSecond .

ais:ix_status_codes a sdl:Column ;
    sdl:columnName "status_codes" ;
    sdl:physicalType sdl:IntegerList .


# =============================================================================
# PART 3: Aggregation Relationships (Broadcasts -> Index)
# =============================================================================
#
# Each index column is precisely derived from broadcast columns via a
# declared aggregation function, grouped by MMSI within each daily file.
# =============================================================================

ais:broadcasts_to_index a sdl:AggregationRelationship ;
    sdl:sourceDataset ais:DailyBroadcasts ;
    sdl:targetDataset ais:DailyIndex ;
    sdl:groupByColumn ais:bc_mmsi ;
    rdfs:comment """The daily index is a per-MMSI aggregation of the daily
        broadcasts. Both datasets share the daily partition scheme, and
        aggregation happens within each partition independently.""" ;

    # --- Simple aggregations ---

    sdl:hasAggregatedColumn [
        sdl:targetColumn ais:ix_message_count ;
        sdl:aggregationSourceColumn ais:bc_mmsi ;  # any column; it's COUNT(*)
        sdl:aggregationFunction sdl:Count
    ] ;

    sdl:hasAggregatedColumn [
        sdl:targetColumn ais:ix_first_timestamp ;
        sdl:aggregationSourceColumn ais:bc_timestamp ;
        sdl:aggregationFunction sdl:Min
    ] ;

    sdl:hasAggregatedColumn [
        sdl:targetColumn ais:ix_last_timestamp ;
        sdl:aggregationSourceColumn ais:bc_timestamp ;
        sdl:aggregationFunction sdl:Max
    ] ;

    # --- Distinct list aggregations ---

    sdl:hasAggregatedColumn [
        sdl:targetColumn ais:ix_vessel_names ;
        sdl:aggregationSourceColumn ais:bc_vessel_name ;
        sdl:aggregationFunction sdl:DistinctList
    ] ;

    sdl:hasAggregatedColumn [
        sdl:targetColumn ais:ix_imos ;
        sdl:aggregationSourceColumn ais:bc_imo ;
        sdl:aggregationFunction sdl:DistinctList
    ] ;

    sdl:hasAggregatedColumn [
        sdl:targetColumn ais:ix_call_signs ;
        sdl:aggregationSourceColumn ais:bc_call_sign ;
        sdl:aggregationFunction sdl:DistinctList
    ] ;

    sdl:hasAggregatedColumn [
        sdl:targetColumn ais:ix_vessel_types ;
        sdl:aggregationSourceColumn ais:bc_vessel_type ;
        sdl:aggregationFunction sdl:DistinctList
    ] ;

    sdl:hasAggregatedColumn [
        sdl:targetColumn ais:ix_cargos ;
        sdl:aggregationSourceColumn ais:bc_cargo ;
        sdl:aggregationFunction sdl:DistinctList
    ] ;

    sdl:hasAggregatedColumn [
        sdl:targetColumn ais:ix_lengths ;
        sdl:aggregationSourceColumn ais:bc_length ;
        sdl:aggregationFunction sdl:DistinctList
    ] ;

    sdl:hasAggregatedColumn [
        sdl:targetColumn ais:ix_widths ;
        sdl:aggregationSourceColumn ais:bc_width ;
        sdl:aggregationFunction sdl:DistinctList
    ] ;

    sdl:hasAggregatedColumn [
        sdl:targetColumn ais:ix_drafts ;
        sdl:aggregationSourceColumn ais:bc_draft ;
        sdl:aggregationFunction sdl:DistinctList
    ] ;

    sdl:hasAggregatedColumn [
        sdl:targetColumn ais:ix_transceiver_classes ;
        sdl:aggregationSourceColumn ais:bc_transceiver ;
        sdl:aggregationFunction sdl:DistinctList
    ] ;

    sdl:hasAggregatedColumn [
        sdl:targetColumn ais:ix_status_codes ;
        sdl:aggregationSourceColumn ais:bc_status ;
        sdl:aggregationFunction sdl:DistinctList
    ] ;

    # --- Spatial extrema ---

    sdl:hasAggregatedColumn [
        sdl:targetColumn ais:ix_min_lat ;
        sdl:aggregationSourceColumn ais:bc_latitude ;
        sdl:aggregationFunction sdl:Min
    ] ;

    sdl:hasAggregatedColumn [
        sdl:targetColumn ais:ix_max_lat ;
        sdl:aggregationSourceColumn ais:bc_latitude ;
        sdl:aggregationFunction sdl:Max
    ] ;

    sdl:hasAggregatedColumn [
        sdl:targetColumn ais:ix_min_lon ;
        sdl:aggregationSourceColumn ais:bc_longitude ;
        sdl:aggregationFunction sdl:Min
    ] ;

    sdl:hasAggregatedColumn [
        sdl:targetColumn ais:ix_max_lon ;
        sdl:aggregationSourceColumn ais:bc_longitude ;
        sdl:aggregationFunction sdl:Max
    ] ;

    # --- Spatial means ---

    sdl:hasAggregatedColumn [
        sdl:targetColumn ais:ix_centroid_lat ;
        sdl:aggregationSourceColumn ais:bc_latitude ;
        sdl:aggregationFunction sdl:Mean ;
        rdfs:comment """Arithmetic mean of latitudes. This is an approximation
            of the centroid; exact centroid would need spherical geometry."""
    ] ;

    sdl:hasAggregatedColumn [
        sdl:targetColumn ais:ix_centroid_lon ;
        sdl:aggregationSourceColumn ais:bc_longitude ;
        sdl:aggregationFunction sdl:Mean ;
        rdfs:comment """Arithmetic mean of longitudes. Known issue: wraps
            incorrectly near the antimeridian."""
    ] ;

    # --- Speed stats ---

    sdl:hasAggregatedColumn [
        sdl:targetColumn ais:ix_sog_min ;
        sdl:aggregationSourceColumn ais:bc_sog ;
        sdl:aggregationFunction sdl:Min
    ] ;

    sdl:hasAggregatedColumn [
        sdl:targetColumn ais:ix_sog_max ;
        sdl:aggregationSourceColumn ais:bc_sog ;
        sdl:aggregationFunction sdl:Max
    ] ;

    sdl:hasAggregatedColumn [
        sdl:targetColumn ais:ix_sog_mean ;
        sdl:aggregationSourceColumn ais:bc_sog ;
        sdl:aggregationFunction sdl:Mean
    ] ;

    # --- H3 cell count ---

    sdl:hasAggregatedColumn [
        sdl:targetColumn ais:ix_h3_cell_count ;
        sdl:aggregationSourceColumn ais:bc_h3_res15 ;
        sdl:aggregationFunction sdl:CountDistinct
    ] ;

    # --- Derived aggregations (require more than one step) ---

    sdl:hasAggregatedColumn [
        sdl:targetColumn ais:ix_duration_s ;
        rdfs:comment """Derived: EXTRACT(EPOCH FROM max(timestamp) - min(timestamp)).
            Not a simple single-column aggregation; it's the difference
            between two aggregates.""" ;
        sdl:aggregationFunction ais:DurationBetweenExtrema ;
        sdl:aggregationSourceColumn ais:bc_timestamp
    ] ;

    sdl:hasAggregatedColumn [
        sdl:targetColumn ais:ix_distance_m ;
        rdfs:comment """Haversine distance between first and last positions
            (ordered by timestamp). A sequential aggregation requiring
            within-group ordering.""" ;
        sdl:aggregationFunction ais:HaversineFirstToLast ;
        sdl:aggregationSourceColumn ais:bc_latitude ;
        sdl:aggregationSourceColumn ais:bc_longitude ;
        sdl:withinGroupOrdering ais:bc_timestamp
    ] ;

    sdl:hasAggregatedColumn [
        sdl:targetColumn ais:ix_max_inter_msg_speed_ms ;
        rdfs:comment """Maximum implied speed between any two consecutive
            messages for this MMSI, in m/s. Computed as:
            max over consecutive pairs of (haversine_distance / time_delta).
            A windowed sequential aggregation. Useful as a data quality
            indicator: implausibly high values suggest MMSI reuse or
            erroneous positions.""" ;
        sdl:aggregationFunction ais:MaxConsecutiveImpliedSpeed ;
        sdl:aggregationSourceColumn ais:bc_latitude ;
        sdl:aggregationSourceColumn ais:bc_longitude ;
        sdl:aggregationSourceColumn ais:bc_timestamp ;
        sdl:withinGroupOrdering ais:bc_timestamp
    ] .


# --- Custom aggregation function definitions ---

ais:DurationBetweenExtrema a rdfs:Resource ;
    rdfs:label "Duration between min and max timestamps" ;
    rdfs:comment "EXTRACT(EPOCH FROM MAX(col) - MIN(col))" ;
    sdl:computationalProfile sdl:FullScanRequired .

ais:HaversineFirstToLast a rdfs:Resource ;
    rdfs:label "Haversine distance from first to last position" ;
    rdfs:comment """Requires ordering by timestamp, takes first and last
        (lat, lon) pair, computes haversine distance in metres.""" ;
    sdl:computationalProfile sdl:SequentialScan .

ais:MaxConsecutiveImpliedSpeed a rdfs:Resource ;
    rdfs:label "Maximum implied speed between consecutive messages" ;
    rdfs:comment """For each consecutive pair of messages (ordered by timestamp),
        computes haversine_distance / time_delta. Returns the maximum.
        This is a windowed aggregation over consecutive pairs.""" ;
    sdl:computationalProfile sdl:SequentialScan .


# =============================================================================
# PART 4: Provenance and Known Deficiencies
# =============================================================================

ais:noaa_provenance a sdl:Provenance ;
    sdl:source <https://marinecadastre.gov/ais/> ;
    sdl:sourceDescription """NOAA Marine Cadastre AIS data. Published as one
        compressed CSV per day. Covers US waters and beyond, sourced from
        US Coast Guard terrestrial and satellite AIS receivers.""" ;

    sdl:hasTransformation [
        a sdl:Transformation ;
        sdl:transformationType "denormalization" ;
        sdl:transformationDescription """NOAA merges static vessel data (name,
            IMO, dimensions, etc.) from AIS Message Types 5/24 into
            position report rows (Message Types 1/2/3/18/19). Original
            message type distinction is lost."""
    ] ;

    sdl:hasTransformation [
        a sdl:Transformation ;
        sdl:transformationType "downsampling" ;
        sdl:transformationDescription """NOAA appears to discard some position
            reports, resulting in lower temporal resolution than the raw
            AIS feed. The exact filtering criteria are not documented."""
    ] ;

    sdl:hasTransformation [
        a sdl:Transformation ;
        sdl:transformationType "local_preprocessing" ;
        sdl:transformationDescription """CSV-to-Parquet conversion with added
            columns: parsed timestamp (from base_date_time string),
            WKB point geometry (from lat/lon), H3 cell index at resolution
            15 (from lat/lon), date column (partition key). Rows ordered
            by MMSI then timestamp."""
    ] .


ais:deficiency_missing_positions a sdl:KnownDeficiency ;
    sdl:deficiencyDescription """Temporal gaps exist within vessel trajectories
        due to NOAA's undocumented downsampling. Trajectory-based analyses
        (distance, speed) may be inaccurate for affected segments.""" ;
    sdl:impact """Distance and duration calculations will underestimate true
        values. Speed calculations between widely-spaced messages may not
        reflect actual vessel behavior.""" ;
    sdl:severity sdl:Moderate .

ais:deficiency_denormalized a sdl:KnownDeficiency ;
    sdl:deficiencyDescription """Static vessel data is denormalized into position
        rows. A vessel's name/IMO/dimensions may appear differently across
        rows due to broadcast timing and the merge process.""" ;
    sdl:impact """Static fields in any single row may be stale or from a
        different time than the position report. The index file's distinct
        lists mitigate this by preserving all observed values.""" ;
    sdl:severity sdl:Minor .

ais:deficiency_mmsi_identity a sdl:KnownDeficiency ;
    sdl:deficiencyDescription """MMSI does not reliably identify a single vessel.
        Known issues: MMSI reuse between vessels, multiple vessels sharing
        an MMSI simultaneously, default/test MMSIs, and spoofing.""" ;
    sdl:impact """Grouping by MMSI may conflate different vessels. The
        max_inter_msg_speed_ms index column can flag likely cases (an
        implausibly high implied speed suggests MMSI reuse).""" ;
    sdl:severity sdl:Moderate .
