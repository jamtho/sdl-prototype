@prefix mnf:    <http://example.org/manifest#> .
@prefix ais:    <http://example.org/ais#> .
@prefix geo:    <http://www.opengis.net/ont/geosparql#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# AIS-NOAA Dataset Description
# =============================================================================
#
# Applies the Manifest vocabulary to describe the preprocessed NOAA Marine Cadastre
# AIS data: daily broadcast files and their companion daily index files.
#
# This serves as the reference example for the Manifest framework.
# =============================================================================


# =============================================================================
# PART 1: AIS Domain Semantic Types
# =============================================================================
#
# These are the opaque leaves — domain-specific types that carry meaning
# beyond what the physical storage type tells you. Each declares its
# required physical type, value constraints, and domain semantics.
# =============================================================================

ais:MMSI a mnf:SemanticType ;
    rdfs:label "Maritime Mobile Service Identity" ;
    rdfs:comment """Nine-digit vessel identifier assigned by flag state. In
        practice: not unique to a vessel (vessels change MMSI, multiple
        vessels sometimes share one, some are garbage). Treat as 'mostly
        identifies a vessel, with known failure modes'.""" ;
    mnf:requiredPhysicalType mnf:Integer ;
    mnf:valueRange [
        mnf:minInclusive 100000000 ;
        mnf:maxInclusive 799999999
    ] ;
    mnf:computationalProfile mnf:SchemaCheckOnly ;
    rdfs:seeAlso <https://www.itu.int/rec/R-REC-M.585/en> .

ais:IMONumber a mnf:SemanticType ;
    rdfs:label "IMO Ship Identification Number" ;
    rdfs:comment """Seven-digit number permanently assigned to a vessel.
        More reliable than MMSI for identity, but not always present in
        AIS data. String because leading 'IMO' prefix is sometimes
        included.""" ;
    mnf:requiredPhysicalType mnf:Varchar .

ais:WGS84Latitude a mnf:SemanticType ;
    rdfs:label "WGS84 Latitude" ;
    mnf:requiredPhysicalType mnf:Double ;
    mnf:unit "degrees" ;
    mnf:valueRange [
        mnf:minInclusive -90.0 ;
        mnf:maxInclusive  90.0
    ] .

ais:WGS84Longitude a mnf:SemanticType ;
    rdfs:label "WGS84 Longitude" ;
    mnf:requiredPhysicalType mnf:Double ;
    mnf:unit "degrees" ;
    mnf:valueRange [
        mnf:minInclusive -180.0 ;
        mnf:maxInclusive  180.0
    ] .

ais:WGS84CoordinatePair a mnf:SemanticType ;
    rdfs:label "WGS84 Coordinate Pair (lat, lon)" ;
    rdfs:comment "A pair of columns jointly representing a WGS84 position." .

ais:SpeedOverGround a mnf:SemanticType ;
    rdfs:label "Speed Over Ground" ;
    mnf:requiredPhysicalType mnf:Double ;
    mnf:unit "knots" ;
    mnf:valueRange [
        mnf:minInclusive 0.0 ;
        mnf:maxInclusive 102.2
    ] ;
    rdfs:comment """AIS SOG: 0.0-102.2 knots in 0.1 knot steps. Value 102.3
        means >=102.2. Null or NaN means not available.""" .

ais:CourseOverGround a mnf:SemanticType ;
    rdfs:label "Course Over Ground" ;
    mnf:requiredPhysicalType mnf:Double ;
    mnf:unit "degrees" ;
    mnf:valueRange [
        mnf:minInclusive 0.0 ;
        mnf:maxExclusive 360.0
    ] ;
    rdfs:comment "Relative to true north. 3600 (36.0 scaled) = not available." .

ais:TrueHeading a mnf:SemanticType ;
    rdfs:label "True Heading" ;
    mnf:requiredPhysicalType mnf:Double ;
    mnf:unit "degrees" ;
    mnf:valueRange [
        mnf:minInclusive 0.0 ;
        mnf:maxExclusive 360.0
    ] ;
    rdfs:comment "511 means not available in raw AIS; may appear as NaN here." .

ais:VesselTypeCode a mnf:SemanticType ;
    rdfs:label "AIS Vessel Type Code" ;
    mnf:requiredPhysicalType mnf:Integer ;
    rdfs:comment """Vessel type as per ITU-R M.1371. Values 0-99. Grouped:
        30-39 fishing, 40-49 HSC, 60-69 passenger, 70-79 cargo,
        80-89 tanker, etc.""" ;
    mnf:valueRange [
        mnf:minInclusive 0 ;
        mnf:maxInclusive 99
    ] .

ais:NavigationalStatus a mnf:SemanticType ;
    rdfs:label "AIS Navigational Status" ;
    mnf:requiredPhysicalType mnf:Integer ;
    rdfs:comment """0=under way using engine, 1=at anchor, 2=not under command,
        3=restricted maneuverability, 5=moored, 7=fishing, 8=under sail,
        15=default/not defined. Per ITU-R M.1371.""" ;
    mnf:valueRange [
        mnf:minInclusive 0 ;
        mnf:maxInclusive 15
    ] .

ais:VesselDraft a mnf:SemanticType ;
    rdfs:label "Vessel Static Draft" ;
    mnf:requiredPhysicalType mnf:Double ;
    mnf:unit "metres" ;
    mnf:valueRange [
        mnf:minInclusive 0.0 ;
        mnf:maxInclusive 25.5
    ] ;
    rdfs:comment "Maximum draught. 0 = not available in raw AIS." .

ais:VesselLength a mnf:SemanticType ;
    rdfs:label "Vessel Length" ;
    mnf:requiredPhysicalType mnf:Double ;
    mnf:unit "metres" .

ais:VesselWidth a mnf:SemanticType ;
    rdfs:label "Vessel Width (Beam)" ;
    mnf:requiredPhysicalType mnf:Double ;
    mnf:unit "metres" .

ais:CargoTypeCode a mnf:SemanticType ;
    rdfs:label "AIS Cargo Type Code" ;
    mnf:requiredPhysicalType mnf:Integer .

ais:CallSign a mnf:SemanticType ;
    rdfs:label "Radio Call Sign" ;
    mnf:requiredPhysicalType mnf:Varchar .

ais:VesselName a mnf:SemanticType ;
    rdfs:label "Vessel Name" ;
    mnf:requiredPhysicalType mnf:Varchar ;
    rdfs:comment """As broadcast by AIS. May contain trailing spaces, be
        truncated, or vary between broadcasts.""" .

ais:TransceiverClass a mnf:SemanticType ;
    rdfs:label "AIS Transceiver Class" ;
    mnf:requiredPhysicalType mnf:Varchar ;
    rdfs:comment "E.g. 'A', 'B', 'A-S'." .

ais:WKBPoint a mnf:SemanticType ;
    rdfs:label "Well-Known Binary Point Geometry" ;
    mnf:requiredPhysicalType mnf:Blob ;
    rdfs:comment "WKB-encoded Point geometry. CRS: WGS84 / EPSG:4326." .

ais:H3CellIndex a mnf:SemanticType ;
    rdfs:label "H3 Hexagonal Cell Index" ;
    mnf:requiredPhysicalType mnf:UBigInt ;
    rdfs:comment "Uber H3 cell index at a declared resolution." .

ais:H3Resolution15 a mnf:SemanticType ;
    rdfs:label "H3 Cell Index at Resolution 15" ;
    rdfs:comment "~0.9 m² cell area. Finest H3 resolution." ;
    # inherits from ais:H3CellIndex conceptually
    mnf:requiredPhysicalType mnf:UBigInt .

ais:AISTimestamp a mnf:SemanticType ;
    rdfs:label "AIS Broadcast Timestamp" ;
    mnf:requiredPhysicalType mnf:TimestampTZ ;
    rdfs:comment "Timestamp of the AIS broadcast, with timezone (UTC)." .

ais:AISRawTimestampString a mnf:SemanticType ;
    rdfs:label "Raw AIS Timestamp String" ;
    mnf:requiredPhysicalType mnf:Varchar ;
    rdfs:comment """Original timestamp string from the NOAA CSV before parsing.
        Retained for traceability.""" .

ais:PartitionDate a mnf:SemanticType ;
    rdfs:label "Partition Date" ;
    mnf:requiredPhysicalType mnf:Date ;
    rdfs:comment """Date value constant within each file, matching the file's
        partition. Embedded as a column for query convenience.""" .

ais:DistanceMetres a mnf:SemanticType ;
    rdfs:label "Distance in Metres" ;
    mnf:requiredPhysicalType mnf:Double ;
    mnf:unit "metres" ;
    mnf:valueRange [ mnf:minInclusive 0.0 ] .

ais:DurationSeconds a mnf:SemanticType ;
    rdfs:label "Duration in Seconds" ;
    mnf:requiredPhysicalType mnf:Double ;
    mnf:unit "seconds" ;
    mnf:valueRange [ mnf:minInclusive 0.0 ] .

ais:SpeedMetresPerSecond a mnf:SemanticType ;
    rdfs:label "Speed in Metres per Second" ;
    mnf:requiredPhysicalType mnf:Double ;
    mnf:unit "m/s" ;
    mnf:valueRange [ mnf:minInclusive 0.0 ] .

ais:MessageCount a mnf:SemanticType ;
    rdfs:label "Count of AIS Messages" ;
    mnf:requiredPhysicalType mnf:BigInt ;
    mnf:valueRange [ mnf:minInclusive 1 ] ;
    rdfs:comment "Must be >= 1 since the group would not exist otherwise." .


# =============================================================================
# PART 2: Datasets and Schemas
# =============================================================================

# -----------------------------------------------------------------------------
# 2a. Daily Broadcasts Dataset
# -----------------------------------------------------------------------------

ais:DailyBroadcasts a mnf:Dataset ;
    rdfs:label "AIS Daily Broadcast Positions" ;
    rdfs:comment """One Parquet file per day containing preprocessed AIS vessel
        position reports from NOAA Marine Cadastre. Denormalized: includes
        static vessel data (name, IMO, dimensions) merged with position
        reports. Ordered by MMSI then timestamp within each file.""" ;
    mnf:rowSemantics mnf:EventRow ;
    mnf:schemaStability mnf:FixedSchema ;

    # --- Columns ---
    mnf:hasColumn
        ais:bc_mmsi ,
        ais:bc_date ,
        ais:bc_base_date_time ,
        ais:bc_latitude ,
        ais:bc_longitude ,
        ais:bc_sog ,
        ais:bc_cog ,
        ais:bc_heading ,
        ais:bc_vessel_name ,
        ais:bc_imo ,
        ais:bc_call_sign ,
        ais:bc_vessel_type ,
        ais:bc_status ,
        ais:bc_length ,
        ais:bc_width ,
        ais:bc_draft ,
        ais:bc_cargo ,
        ais:bc_transceiver ,
        ais:bc_timestamp ,
        ais:bc_geometry ,
        ais:bc_h3_res15 ;

    # --- Column groups ---
    mnf:hasColumnGroup ais:bc_position ;

    # --- Physical layout ---
    mnf:hasPhysicalLayout ais:bc_layout ;

    # --- Partition scheme ---
    mnf:partitionedBy ais:daily_date_partition ;

    # --- Provenance ---
    mnf:hasProvenance ais:noaa_provenance ;

    # --- Known deficiencies ---
    mnf:hasKnownDeficiency
        ais:deficiency_missing_positions ,
        ais:deficiency_denormalized ,
        ais:deficiency_mmsi_identity .


# --- Broadcast column definitions ---

ais:bc_mmsi a mnf:Column ;
    mnf:columnName "mmsi" ;
    mnf:physicalType mnf:Integer ;
    mnf:semanticType ais:MMSI ;
    mnf:nullable true .

ais:bc_date a mnf:Column ;
    mnf:columnName "date" ;
    mnf:physicalType mnf:Date ;
    mnf:semanticType ais:PartitionDate ;
    mnf:nullable true .

ais:bc_base_date_time a mnf:Column ;
    mnf:columnName "base_date_time" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ais:AISRawTimestampString ;
    mnf:nullable true .

ais:bc_latitude a mnf:Column ;
    mnf:columnName "latitude" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType ais:WGS84Latitude ;
    mnf:nullable true .

ais:bc_longitude a mnf:Column ;
    mnf:columnName "longitude" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType ais:WGS84Longitude ;
    mnf:nullable true .

ais:bc_sog a mnf:Column ;
    mnf:columnName "sog" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType ais:SpeedOverGround ;
    mnf:nullable true .

ais:bc_cog a mnf:Column ;
    mnf:columnName "cog" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType ais:CourseOverGround ;
    mnf:nullable true .

ais:bc_heading a mnf:Column ;
    mnf:columnName "heading" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType ais:TrueHeading ;
    mnf:nullable true .

ais:bc_vessel_name a mnf:Column ;
    mnf:columnName "vessel_name" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ais:VesselName ;
    mnf:nullable true .

ais:bc_imo a mnf:Column ;
    mnf:columnName "imo" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ais:IMONumber ;
    mnf:nullable true .

ais:bc_call_sign a mnf:Column ;
    mnf:columnName "call_sign" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ais:CallSign ;
    mnf:nullable true .

ais:bc_vessel_type a mnf:Column ;
    mnf:columnName "vessel_type" ;
    mnf:physicalType mnf:Integer ;
    mnf:semanticType ais:VesselTypeCode ;
    mnf:nullable true .

ais:bc_status a mnf:Column ;
    mnf:columnName "status" ;
    mnf:physicalType mnf:Integer ;
    mnf:semanticType ais:NavigationalStatus ;
    mnf:nullable true .

ais:bc_length a mnf:Column ;
    mnf:columnName "length" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType ais:VesselLength ;
    mnf:nullable true .

ais:bc_width a mnf:Column ;
    mnf:columnName "width" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType ais:VesselWidth ;
    mnf:nullable true .

ais:bc_draft a mnf:Column ;
    mnf:columnName "draft" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType ais:VesselDraft ;
    mnf:nullable true .

ais:bc_cargo a mnf:Column ;
    mnf:columnName "cargo" ;
    mnf:physicalType mnf:Integer ;
    mnf:semanticType ais:CargoTypeCode ;
    mnf:nullable true .

ais:bc_transceiver a mnf:Column ;
    mnf:columnName "transceiver" ;
    mnf:physicalType mnf:Varchar ;
    mnf:semanticType ais:TransceiverClass ;
    mnf:nullable true .

ais:bc_timestamp a mnf:Column ;
    mnf:columnName "timestamp" ;
    mnf:physicalType mnf:TimestampTZ ;
    mnf:semanticType ais:AISTimestamp ;
    mnf:nullable true .

ais:bc_geometry a mnf:Column ;
    mnf:columnName "geometry" ;
    mnf:physicalType mnf:Blob ;
    mnf:semanticType ais:WKBPoint ;
    mnf:nullable true .

ais:bc_h3_res15 a mnf:Column ;
    mnf:columnName "h3_res15" ;
    mnf:physicalType mnf:UBigInt ;
    mnf:semanticType ais:H3Resolution15 ;
    mnf:nullable true .


# --- Coordinate pair column group ---

ais:bc_position a mnf:ColumnGroup ;
    mnf:groupSemanticType ais:WGS84CoordinatePair ;
    mnf:groupMember ais:bc_latitude ;
    mnf:groupMember ais:bc_longitude .

ais:bc_latitude mnf:memberOf ais:bc_position .
ais:bc_longitude mnf:memberOf ais:bc_position .


# --- Derivations ---

ais:derive_timestamp a mnf:Derivation ;
    rdfs:comment "timestamp is parsed from base_date_time string." ;
    mnf:derivedColumn ais:bc_timestamp ;
    mnf:sourceColumn ais:bc_base_date_time ;
    mnf:derivationFunction ais:ParseTimestamp ;
    mnf:hasDerivationProperty mnf:Deterministic ;
    mnf:hasDerivationProperty mnf:Invertible .

ais:derive_geometry a mnf:Derivation ;
    rdfs:comment "geometry is WKB Point constructed from (latitude, longitude)." ;
    mnf:derivedColumn ais:bc_geometry ;
    mnf:sourceColumn ais:bc_latitude ;
    mnf:sourceColumn ais:bc_longitude ;
    mnf:derivationFunction ais:PointFromWGS84 ;
    mnf:hasDerivationProperty mnf:Deterministic ;
    mnf:hasDerivationProperty mnf:Invertible .

ais:derive_h3 a mnf:Derivation ;
    rdfs:comment "h3_res15 is computed from (latitude, longitude) at resolution 15." ;
    mnf:derivedColumn ais:bc_h3_res15 ;
    mnf:sourceColumn ais:bc_latitude ;
    mnf:sourceColumn ais:bc_longitude ;
    mnf:derivationFunction ais:H3IndexFromWGS84Res15 ;
    mnf:hasDerivationProperty mnf:Deterministic ;
    mnf:hasDerivationProperty mnf:Lossy ;
    rdfs:comment "Lossy: multiple lat/lon pairs map to same H3 cell." .


# --- Physical layout ---

ais:bc_layout a mnf:PhysicalLayout ;
    mnf:fileFormat mnf:Parquet ;
    mnf:hasRowOrdering ais:bc_ordering .

ais:bc_ordering a mnf:RowOrdering ;
    mnf:hasOrderingKey [
        a mnf:OrderingKey ;
        mnf:keyColumn ais:bc_mmsi ;
        mnf:keyDirection mnf:Ascending ;
        mnf:keyPrecedence 1 ;
        mnf:orderingSemantic mnf:ClusteringForIndex ;
        rdfs:comment """Primary sort by MMSI clusters all broadcasts for a
            given vessel contiguously. This enables Parquet row group
            min/max indexes to rapidly skip irrelevant groups when
            filtering by MMSI. The sort direction is arbitrary; the
            clustering is what matters."""
    ] ;
    mnf:hasOrderingKey [
        a mnf:OrderingKey ;
        mnf:keyColumn ais:bc_timestamp ;
        mnf:keyDirection mnf:Ascending ;
        mnf:keyPrecedence 2 ;
        mnf:orderingSemantic mnf:MeaningfulSequence ;
        rdfs:comment """Within each MMSI cluster, broadcasts are in
            chronological order. This ordering is both performance-critical
            (enables timestamp range pruning within a vessel) and
            semantically meaningful (represents the vessel's trajectory
            as a time series)."""
    ] .


# --- Partition scheme ---

ais:daily_date_partition a mnf:PartitionScheme ;
    mnf:partitionColumn ais:bc_date ;
    mnf:partitionGranularity mnf:Daily ;
    mnf:pathTemplate "broadcasts/{year}/ais-{date}.parquet" ;
    mnf:redundantPartitionKey ais:bc_date ;
    rdfs:comment """One file per UTC day. The 'date' column in each file is
        constant and matches the file's date. Path pattern uses ISO date
        format (YYYY-MM-DD) for {date} and four-digit year for {year}.""" .


# --- Constraints on the broadcast dataset ---

ais:bc_date_constant a mnf:DatasetConstraint ;
    mnf:appliesToColumn ais:bc_date ;
    rdfs:label "Date column is constant within each file" ;
    rdfs:comment """Every row in a single Parquet file has the same 'date'
        value, matching the file's partition date.""" ;
    mnf:computationalProfile mnf:FullScanRequired ;
    mnf:validator [
        a mnf:DuckDBValidator ;
        mnf:query "SELECT COUNT(DISTINCT date) = 1 FROM data"
    ] .

ais:bc_timestamp_within_date a mnf:DatasetConstraint ;
    mnf:appliesToColumn ais:bc_timestamp ;
    rdfs:label "All timestamps fall within the partition date (UTC)" ;
    rdfs:comment """The timestamp column values should have a UTC date
        matching the partition date column.""" ;
    mnf:computationalProfile mnf:FullScanRequired .

ais:bc_ordered_within_mmsi a mnf:Constraint ;
    a mnf:Grouped ;
    mnf:groupingColumn ais:bc_mmsi ;
    mnf:innerConstraint [
        a mnf:Ordered ;
        mnf:orderingColumn ais:bc_timestamp ;
        mnf:innerConstraint ais:MonotonicallyNonDecreasing
    ] ;
    rdfs:label "Timestamps non-decreasing within each MMSI group" ;
    mnf:computationalProfile mnf:SequentialScan .

# Leaf constraint: monotonically non-decreasing sequence
ais:MonotonicallyNonDecreasing a mnf:SequenceConstraint ;
    rdfs:label "Values are monotonically non-decreasing" ;
    mnf:computationalProfile mnf:SequentialScan ;
    mnf:validator [
        a mnf:PythonValidator ;
        mnf:module "manifest.validators.sequence" ;
        mnf:function "check_monotonic_nondecreasing"
    ] .


# -----------------------------------------------------------------------------
# 2b. Daily Index Dataset
# -----------------------------------------------------------------------------

ais:DailyIndex a mnf:Dataset ;
    rdfs:label "AIS Daily Vessel Index" ;
    rdfs:comment """One Parquet file per day, one row per MMSI observed that
        day. Summarises the broadcast data for quick vessel-level queries
        across the full time range.""" ;
    mnf:rowSemantics mnf:AggregateRow ;
    mnf:schemaStability mnf:FixedSchema ;

    mnf:hasColumn
        ais:ix_mmsi ,
        ais:ix_date ,
        ais:ix_vessel_names ,
        ais:ix_imos ,
        ais:ix_call_signs ,
        ais:ix_vessel_types ,
        ais:ix_cargos ,
        ais:ix_lengths ,
        ais:ix_widths ,
        ais:ix_drafts ,
        ais:ix_transceiver_classes ,
        ais:ix_message_count ,
        ais:ix_first_timestamp ,
        ais:ix_last_timestamp ,
        ais:ix_duration_s ,
        ais:ix_centroid_lat ,
        ais:ix_centroid_lon ,
        ais:ix_min_lat ,
        ais:ix_max_lat ,
        ais:ix_min_lon ,
        ais:ix_max_lon ,
        ais:ix_distance_m ,
        ais:ix_h3_cell_count ,
        ais:ix_sog_min ,
        ais:ix_sog_max ,
        ais:ix_sog_mean ,
        ais:ix_max_inter_msg_speed_ms ,
        ais:ix_status_codes ;

    mnf:partitionedBy ais:daily_date_partition ;
    mnf:hasPhysicalLayout [
        a mnf:PhysicalLayout ;
        mnf:fileFormat mnf:Parquet
    ] .

# Companion relationship
ais:DailyIndex mnf:companionOf ais:DailyBroadcasts .


# --- Index column definitions (abbreviated: showing types and semantics) ---

ais:ix_mmsi a mnf:Column ;
    mnf:columnName "mmsi" ;
    mnf:physicalType mnf:Integer ;
    mnf:semanticType ais:MMSI .

ais:ix_date a mnf:Column ;
    mnf:columnName "date" ;
    mnf:physicalType mnf:Date ;
    mnf:semanticType ais:PartitionDate .

ais:ix_vessel_names a mnf:Column ;
    mnf:columnName "vessel_names" ;
    mnf:physicalType mnf:VarcharList ;
    rdfs:comment "Distinct vessel names broadcast by this MMSI on this day." .

ais:ix_imos a mnf:Column ;
    mnf:columnName "imos" ;
    mnf:physicalType mnf:VarcharList .

ais:ix_call_signs a mnf:Column ;
    mnf:columnName "call_signs" ;
    mnf:physicalType mnf:VarcharList .

ais:ix_vessel_types a mnf:Column ;
    mnf:columnName "vessel_types" ;
    mnf:physicalType mnf:IntegerList .

ais:ix_cargos a mnf:Column ;
    mnf:columnName "cargos" ;
    mnf:physicalType mnf:IntegerList .

ais:ix_lengths a mnf:Column ;
    mnf:columnName "lengths" ;
    mnf:physicalType mnf:DoubleList .

ais:ix_widths a mnf:Column ;
    mnf:columnName "widths" ;
    mnf:physicalType mnf:DoubleList .

ais:ix_drafts a mnf:Column ;
    mnf:columnName "drafts" ;
    mnf:physicalType mnf:DoubleList .

ais:ix_transceiver_classes a mnf:Column ;
    mnf:columnName "transceiver_classes" ;
    mnf:physicalType mnf:VarcharList .

ais:ix_message_count a mnf:Column ;
    mnf:columnName "message_count" ;
    mnf:physicalType mnf:BigInt ;
    mnf:semanticType ais:MessageCount .

ais:ix_first_timestamp a mnf:Column ;
    mnf:columnName "first_timestamp" ;
    mnf:physicalType mnf:TimestampTZ ;
    mnf:semanticType ais:AISTimestamp .

ais:ix_last_timestamp a mnf:Column ;
    mnf:columnName "last_timestamp" ;
    mnf:physicalType mnf:TimestampTZ ;
    mnf:semanticType ais:AISTimestamp .

ais:ix_duration_s a mnf:Column ;
    mnf:columnName "duration_s" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType ais:DurationSeconds .

ais:ix_centroid_lat a mnf:Column ;
    mnf:columnName "centroid_lat" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType ais:WGS84Latitude .

ais:ix_centroid_lon a mnf:Column ;
    mnf:columnName "centroid_lon" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType ais:WGS84Longitude .

ais:ix_min_lat a mnf:Column ;
    mnf:columnName "min_lat" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType ais:WGS84Latitude .

ais:ix_max_lat a mnf:Column ;
    mnf:columnName "max_lat" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType ais:WGS84Latitude .

ais:ix_min_lon a mnf:Column ;
    mnf:columnName "min_lon" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType ais:WGS84Longitude .

ais:ix_max_lon a mnf:Column ;
    mnf:columnName "max_lon" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType ais:WGS84Longitude .

ais:ix_distance_m a mnf:Column ;
    mnf:columnName "distance_m" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType ais:DistanceMetres .

ais:ix_h3_cell_count a mnf:Column ;
    mnf:columnName "h3_cell_count" ;
    mnf:physicalType mnf:BigInt .

ais:ix_sog_min a mnf:Column ;
    mnf:columnName "sog_min" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType ais:SpeedOverGround .

ais:ix_sog_max a mnf:Column ;
    mnf:columnName "sog_max" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType ais:SpeedOverGround .

ais:ix_sog_mean a mnf:Column ;
    mnf:columnName "sog_mean" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType ais:SpeedOverGround .

ais:ix_max_inter_msg_speed_ms a mnf:Column ;
    mnf:columnName "max_inter_msg_speed_ms" ;
    mnf:physicalType mnf:Double ;
    mnf:semanticType ais:SpeedMetresPerSecond .

ais:ix_status_codes a mnf:Column ;
    mnf:columnName "status_codes" ;
    mnf:physicalType mnf:IntegerList .


# =============================================================================
# PART 3: Aggregation Relationships (Broadcasts -> Index)
# =============================================================================
#
# Each index column is precisely derived from broadcast columns via a
# declared aggregation function, grouped by MMSI within each daily file.
# =============================================================================

ais:broadcasts_to_index a mnf:AggregationRelationship ;
    mnf:sourceDataset ais:DailyBroadcasts ;
    mnf:targetDataset ais:DailyIndex ;
    mnf:groupByColumn ais:bc_mmsi ;
    rdfs:comment """The daily index is a per-MMSI aggregation of the daily
        broadcasts. Both datasets share the daily partition scheme, and
        aggregation happens within each partition independently.""" ;

    # --- Simple aggregations ---

    mnf:hasAggregatedColumn [
        mnf:targetColumn ais:ix_message_count ;
        mnf:aggregationSourceColumn ais:bc_mmsi ;  # any column; it's COUNT(*)
        mnf:aggregationFunction mnf:Count
    ] ;

    mnf:hasAggregatedColumn [
        mnf:targetColumn ais:ix_first_timestamp ;
        mnf:aggregationSourceColumn ais:bc_timestamp ;
        mnf:aggregationFunction mnf:Min
    ] ;

    mnf:hasAggregatedColumn [
        mnf:targetColumn ais:ix_last_timestamp ;
        mnf:aggregationSourceColumn ais:bc_timestamp ;
        mnf:aggregationFunction mnf:Max
    ] ;

    # --- Distinct list aggregations ---

    mnf:hasAggregatedColumn [
        mnf:targetColumn ais:ix_vessel_names ;
        mnf:aggregationSourceColumn ais:bc_vessel_name ;
        mnf:aggregationFunction mnf:DistinctList
    ] ;

    mnf:hasAggregatedColumn [
        mnf:targetColumn ais:ix_imos ;
        mnf:aggregationSourceColumn ais:bc_imo ;
        mnf:aggregationFunction mnf:DistinctList
    ] ;

    mnf:hasAggregatedColumn [
        mnf:targetColumn ais:ix_call_signs ;
        mnf:aggregationSourceColumn ais:bc_call_sign ;
        mnf:aggregationFunction mnf:DistinctList
    ] ;

    mnf:hasAggregatedColumn [
        mnf:targetColumn ais:ix_vessel_types ;
        mnf:aggregationSourceColumn ais:bc_vessel_type ;
        mnf:aggregationFunction mnf:DistinctList
    ] ;

    mnf:hasAggregatedColumn [
        mnf:targetColumn ais:ix_cargos ;
        mnf:aggregationSourceColumn ais:bc_cargo ;
        mnf:aggregationFunction mnf:DistinctList
    ] ;

    mnf:hasAggregatedColumn [
        mnf:targetColumn ais:ix_lengths ;
        mnf:aggregationSourceColumn ais:bc_length ;
        mnf:aggregationFunction mnf:DistinctList
    ] ;

    mnf:hasAggregatedColumn [
        mnf:targetColumn ais:ix_widths ;
        mnf:aggregationSourceColumn ais:bc_width ;
        mnf:aggregationFunction mnf:DistinctList
    ] ;

    mnf:hasAggregatedColumn [
        mnf:targetColumn ais:ix_drafts ;
        mnf:aggregationSourceColumn ais:bc_draft ;
        mnf:aggregationFunction mnf:DistinctList
    ] ;

    mnf:hasAggregatedColumn [
        mnf:targetColumn ais:ix_transceiver_classes ;
        mnf:aggregationSourceColumn ais:bc_transceiver ;
        mnf:aggregationFunction mnf:DistinctList
    ] ;

    mnf:hasAggregatedColumn [
        mnf:targetColumn ais:ix_status_codes ;
        mnf:aggregationSourceColumn ais:bc_status ;
        mnf:aggregationFunction mnf:DistinctList
    ] ;

    # --- Spatial extrema ---

    mnf:hasAggregatedColumn [
        mnf:targetColumn ais:ix_min_lat ;
        mnf:aggregationSourceColumn ais:bc_latitude ;
        mnf:aggregationFunction mnf:Min
    ] ;

    mnf:hasAggregatedColumn [
        mnf:targetColumn ais:ix_max_lat ;
        mnf:aggregationSourceColumn ais:bc_latitude ;
        mnf:aggregationFunction mnf:Max
    ] ;

    mnf:hasAggregatedColumn [
        mnf:targetColumn ais:ix_min_lon ;
        mnf:aggregationSourceColumn ais:bc_longitude ;
        mnf:aggregationFunction mnf:Min
    ] ;

    mnf:hasAggregatedColumn [
        mnf:targetColumn ais:ix_max_lon ;
        mnf:aggregationSourceColumn ais:bc_longitude ;
        mnf:aggregationFunction mnf:Max
    ] ;

    # --- Spatial means ---

    mnf:hasAggregatedColumn [
        mnf:targetColumn ais:ix_centroid_lat ;
        mnf:aggregationSourceColumn ais:bc_latitude ;
        mnf:aggregationFunction mnf:Mean ;
        rdfs:comment """Arithmetic mean of latitudes. This is an approximation
            of the centroid; exact centroid would need spherical geometry."""
    ] ;

    mnf:hasAggregatedColumn [
        mnf:targetColumn ais:ix_centroid_lon ;
        mnf:aggregationSourceColumn ais:bc_longitude ;
        mnf:aggregationFunction mnf:Mean ;
        rdfs:comment """Arithmetic mean of longitudes. Known issue: wraps
            incorrectly near the antimeridian."""
    ] ;

    # --- Speed stats ---

    mnf:hasAggregatedColumn [
        mnf:targetColumn ais:ix_sog_min ;
        mnf:aggregationSourceColumn ais:bc_sog ;
        mnf:aggregationFunction mnf:Min
    ] ;

    mnf:hasAggregatedColumn [
        mnf:targetColumn ais:ix_sog_max ;
        mnf:aggregationSourceColumn ais:bc_sog ;
        mnf:aggregationFunction mnf:Max
    ] ;

    mnf:hasAggregatedColumn [
        mnf:targetColumn ais:ix_sog_mean ;
        mnf:aggregationSourceColumn ais:bc_sog ;
        mnf:aggregationFunction mnf:Mean
    ] ;

    # --- H3 cell count ---

    mnf:hasAggregatedColumn [
        mnf:targetColumn ais:ix_h3_cell_count ;
        mnf:aggregationSourceColumn ais:bc_h3_res15 ;
        mnf:aggregationFunction mnf:CountDistinct
    ] ;

    # --- Derived aggregations (require more than one step) ---

    mnf:hasAggregatedColumn [
        mnf:targetColumn ais:ix_duration_s ;
        rdfs:comment """Derived: EXTRACT(EPOCH FROM max(timestamp) - min(timestamp)).
            Not a simple single-column aggregation; it's the difference
            between two aggregates.""" ;
        mnf:aggregationFunction ais:DurationBetweenExtrema ;
        mnf:aggregationSourceColumn ais:bc_timestamp
    ] ;

    mnf:hasAggregatedColumn [
        mnf:targetColumn ais:ix_distance_m ;
        rdfs:comment """Haversine distance between first and last positions
            (ordered by timestamp). A sequential aggregation requiring
            within-group ordering.""" ;
        mnf:aggregationFunction ais:HaversineFirstToLast ;
        mnf:aggregationSourceColumn ais:bc_latitude ;
        mnf:aggregationSourceColumn ais:bc_longitude ;
        mnf:withinGroupOrdering ais:bc_timestamp
    ] ;

    mnf:hasAggregatedColumn [
        mnf:targetColumn ais:ix_max_inter_msg_speed_ms ;
        rdfs:comment """Maximum implied speed between any two consecutive
            messages for this MMSI, in m/s. Computed as:
            max over consecutive pairs of (haversine_distance / time_delta).
            A windowed sequential aggregation. Useful as a data quality
            indicator: implausibly high values suggest MMSI reuse or
            erroneous positions.""" ;
        mnf:aggregationFunction ais:MaxConsecutiveImpliedSpeed ;
        mnf:aggregationSourceColumn ais:bc_latitude ;
        mnf:aggregationSourceColumn ais:bc_longitude ;
        mnf:aggregationSourceColumn ais:bc_timestamp ;
        mnf:withinGroupOrdering ais:bc_timestamp
    ] .


# --- Custom aggregation function definitions ---

ais:DurationBetweenExtrema a rdfs:Resource ;
    rdfs:label "Duration between min and max timestamps" ;
    rdfs:comment "EXTRACT(EPOCH FROM MAX(col) - MIN(col))" ;
    mnf:computationalProfile mnf:FullScanRequired .

ais:HaversineFirstToLast a rdfs:Resource ;
    rdfs:label "Haversine distance from first to last position" ;
    rdfs:comment """Requires ordering by timestamp, takes first and last
        (lat, lon) pair, computes haversine distance in metres.""" ;
    mnf:computationalProfile mnf:SequentialScan .

ais:MaxConsecutiveImpliedSpeed a rdfs:Resource ;
    rdfs:label "Maximum implied speed between consecutive messages" ;
    rdfs:comment """For each consecutive pair of messages (ordered by timestamp),
        computes haversine_distance / time_delta. Returns the maximum.
        This is a windowed aggregation over consecutive pairs.""" ;
    mnf:computationalProfile mnf:SequentialScan .


# =============================================================================
# PART 4: Provenance and Known Deficiencies
# =============================================================================

ais:noaa_provenance a mnf:Provenance ;
    mnf:source <https://marinecadastre.gov/ais/> ;
    mnf:sourceDescription """NOAA Marine Cadastre AIS data. Published as one
        compressed CSV per day. Covers US waters and beyond, sourced from
        US Coast Guard terrestrial and satellite AIS receivers.""" ;

    mnf:hasTransformation [
        a mnf:Transformation ;
        mnf:transformationType "denormalization" ;
        mnf:transformationDescription """NOAA merges static vessel data (name,
            IMO, dimensions, etc.) from AIS Message Types 5/24 into
            position report rows (Message Types 1/2/3/18/19). Original
            message type distinction is lost."""
    ] ;

    mnf:hasTransformation [
        a mnf:Transformation ;
        mnf:transformationType "downsampling" ;
        mnf:transformationDescription """NOAA appears to discard some position
            reports, resulting in lower temporal resolution than the raw
            AIS feed. The exact filtering criteria are not documented."""
    ] ;

    mnf:hasTransformation [
        a mnf:Transformation ;
        mnf:transformationType "local_preprocessing" ;
        mnf:transformationDescription """CSV-to-Parquet conversion with added
            columns: parsed timestamp (from base_date_time string),
            WKB point geometry (from lat/lon), H3 cell index at resolution
            15 (from lat/lon), date column (partition key). Rows ordered
            by MMSI then timestamp."""
    ] .


ais:deficiency_missing_positions a mnf:KnownDeficiency ;
    mnf:deficiencyDescription """Temporal gaps exist within vessel trajectories
        due to NOAA's undocumented downsampling. Trajectory-based analyses
        (distance, speed) may be inaccurate for affected segments.""" ;
    mnf:impact """Distance and duration calculations will underestimate true
        values. Speed calculations between widely-spaced messages may not
        reflect actual vessel behavior.""" ;
    mnf:severity mnf:Moderate .

ais:deficiency_denormalized a mnf:KnownDeficiency ;
    mnf:deficiencyDescription """Static vessel data is denormalized into position
        rows. A vessel's name/IMO/dimensions may appear differently across
        rows due to broadcast timing and the merge process.""" ;
    mnf:impact """Static fields in any single row may be stale or from a
        different time than the position report. The index file's distinct
        lists mitigate this by preserving all observed values.""" ;
    mnf:severity mnf:Minor .

ais:deficiency_mmsi_identity a mnf:KnownDeficiency ;
    mnf:deficiencyDescription """MMSI does not reliably identify a single vessel.
        Known issues: MMSI reuse between vessels, multiple vessels sharing
        an MMSI simultaneously, default/test MMSIs, and spoofing.""" ;
    mnf:impact """Grouping by MMSI may conflate different vessels. The
        max_inter_msg_speed_ms index column can flag likely cases (an
        implausibly high implied speed suggests MMSI reuse).""" ;
    mnf:severity mnf:Moderate .
